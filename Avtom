            wb = Workbook(); ws = wb.active; ws.title = "Замовлення"
            thin = Side(style="thin"); med = Side(style="medium")
            bd_all   = Border(left=thin, right=thin, top=thin, bottom=thin)
            bd_top   = Border(left=thin, right=thin, top=med, bottom=thin)
            fnt_title = Font(name="Arial", size=13, bold=True)
            fnt_sub   = Font(name="Arial", size=9)
            fnt_hdr   = Font(name="Arial", size=10, bold=True, color="FFFFFF")
            fnt_data  = Font(name="Arial", size=9)
            fnt_red   = Font(name="Arial", size=9, bold=True, color="DC2626")
            fnt_total = Font(name="Arial", size=10, bold=True)
            fill_hdr   = PatternFill("solid", start_color="3B82F6")
            fill_order = PatternFill("solid", start_color="FEF2F2")
            fill_ok    = PatternFill("solid", start_color="F0FDF4")
            fill_tot   = PatternFill("solid", start_color="F1F5F9")
            al_l = Alignment(horizontal="left",   vertical="center")
            al_c = Alignment(horizontal="center", vertical="center")
            al_r = Alignment(horizontal="right",  vertical="center")
            now = datetime.now()                                        # поточний момент
            ws.merge_cells("A1:F1")
            ws["A1"] = f"Звіт замовлень - {now.strftime('%d.%m.%Y %H:%M')}"
            ws["A1"].font = fnt_title; ws["A1"].alignment = al_l
            ws.row_dimensions[1].height = 24
            ws["A2"] = f"Підприємство: {self._exp_org.get()}   |   Склад: {self._exp_wh.get()}"
            ws["A2"].font = fnt_sub; ws["A2"].alignment = al_l
            ws.row_dimensions[2].height = 16
            headers = [self.T_("col_name"),self.T_("col_unit"),self.T_("col_current"),
                       self.T_("col_min"),self.T_("col_reorder"),self.T_("col_order_qty")]
            col_widths = [42, 8, 16, 14, 18, 16]
            for ci, (hdr, cw) in enumerate(zip(headers, col_widths), 1):
                c = ws.cell(row=4, column=ci, value=hdr)
                c.font = fnt_hdr; c.fill = fill_hdr
                c.alignment = al_l if ci == 1 else al_c
                c.border = bd_all
                ws.column_dimensions[get_column_letter(ci)].width = cw
            ws.row_dimensions[4].height = 20
            row = 5; tot_order = 0.0; order_count = 0                   # лічильник відображених
            for idx, p in enumerate(self.model.data["products"]):       # перебрати товари
                name   = p["name"]; unit = p.get("unit", self.T_("pcs"))
                cur    = stocks.get(name, 0.0)
                min_st = p["min_stock"]
                rp     = self.model.get_reorder_point(p)                # точка замовлення
                need   = self.model.get_order_qty(p, cur)               # скільки замовити
                needs_order = need > 0
                row_fill = fill_order if needs_order else (fill_ok if idx % 2 == 0 else None)
                for ci, (val, al) in enumerate([
                    (name, al_l),(unit, al_c),(cur, al_r),(min_st, al_r),(rp, al_r),
                    (need if needs_order else "-", al_r)
                ], 1):
                    c = ws.cell(row=row, column=ci, value=val)
                    c.border = bd_all; c.alignment = al
                    c.font = fnt_red if ci == 6 and needs_order else fnt_data
                    if ci in (3,4,5) and isinstance(val, (int,float)): c.number_format = "#,##0.##"
                    if ci == 6 and isinstance(val, float): c.number_format = "#,##0.##"
                    if row_fill: c.fill = row_fill
                if needs_order: tot_order += need; order_count += 1     # збільшити лічильник
                ws.row_dimensions[row].height = 16; row += 1
            for ci, (val, al) in enumerate([
                ("Разом до замовлення", al_l),(f"{order_count} поз.", al_c),
                ("",""),("",""),("",""),
                (round(tot_order,2) if tot_order else "-", al_r)
            ], 1):
                c = ws.cell(row=row, column=ci, value=val)
                c.font = fnt_total; c.alignment = al
                c.border = bd_top; c.fill = fill_tot
                if ci == 6 and isinstance(val, float): c.number_format = "#,##0.##"
            ws.row_dimensions[row].height = 18
            row += 2
            ws.cell(row=row, column=1, value="🔴 Червоний - потрібне замовлення").font = fnt_sub
            ws.cell(row=row+1, column=1, value="🟢 Зелений - залишок в нормі").font = fnt_sub
            ws.freeze_panes = "A5"
            ws.print_title_rows = "4:4"
            ws.page_setup.orientation = ws.ORIENTATION_LANDSCAPE
            ws.page_setup.paperSize   = ws.PAPERSIZE_A4
            wb.save(path)
            self._status(f"Звіт замовлення → {path}", C["success"])
            messagebox.showinfo(self.T_("done_title"),
                                f"✅ Файл збережено:\n{path}\n\nПозицій до замовлення: {order_count}")
        except Exception as e:
            messagebox.showerror(self.T_("error_title"), str(e))        # показати помилку

    # Вкладка "Статистика"
