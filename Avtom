    # Методи імпорту даних з файлів 1С:Підприємство / BAS ERP
    # Підтримуються формати xlsx та csv.
    # Програма розпізнає колонки за ключовими словами в заголовку,
    # що забезпечує сумісність з різними версіями вивантажень.
    def _import_1c_xlsx(self):

        if not OPENPYXL_OK:
            messagebox.showerror("Помилка",                             # показати помилку
                "Бібліотека openpyxl не встановлена.\n\n"
                "Встановіть її командою:\n"
                ".venv\\Scripts\\python.exe -m pip install openpyxl\n\n"
                "або скористайтесь експортом у форматі CSV.")
            return                                                      # вийти з методу
        path = filedialog.askopenfilename(
            title="Відкрити файл 1С/BAS",
            filetypes=[("Excel файли", "*.xlsx *.xls"), ("Всі файли", "*.*")])
        if not path:
            return                                                      # вийти з методу
        try:
            wb = load_workbook(path, data_only=True)
            ws = wb.active
            result = self._parse_1c_sheet(ws)
            self._apply_1c_import(result, path)
        except Exception as e:
            messagebox.showerror("Помилка імпорту", f"Не вдалося прочитати файл:\n{e}") # показати помилку

    def _import_1c_csv(self):
        path = filedialog.askopenfilename(
            title="Відкрити CSV з 1С/BAS",
            filetypes=[("CSV файли", "*.csv"), ("Всі файли", "*.*")])
        if not path:
            return                                                      # вийти з методу
        try:
            rows = []
            for enc in ("utf-8-sig", "utf-8", "cp1251", "cp1252"):
                try:
                    with open(path, "r", encoding=enc, newline="") as f:
                        rows = list(csv.reader(f, delimiter=";"))
                    break
                except UnicodeDecodeError:
                    continue                                            # перейти до наступного
            result = self._parse_1c_csv_rows(rows)
            self._apply_1c_import(result, path)
        except Exception as e:
            messagebox.showerror("Помилка імпорту", f"Не вдалося прочитати CSV:\n{e}") # показати помилку

    def _parse_1c_sheet(self, ws):
        header_row = None
        for row in ws.iter_rows(values_only=True):
            row_vals = [str(c).strip() if c is not None else "" for c in row]
            if any("номенклатур" in v.lower() for v in row_vals):
                header_row = row_vals
                break
        if header_row is None:
            raise ValueError("Не знайдено рядок 'Номенклатура' у файлі.") # спровокувати помилку

        def find_col(keywords):
            for i, h in enumerate(header_row):
                if any(k in h.lower() for k in keywords):
                    return i                                            # вийти з методу
            return None                                                 # вийти з методу

        col_name    = find_col(["номенклатур"])
        col_end     = find_col(["кінець", "конец", "end"])
        col_start   = find_col(["початок", "начало", "start"])
        col_income  = find_col(["прихід", "приход", "income"])
        col_expense = find_col(["розхід", "расход", "expense"])
        col_unit    = find_col(["одиниц", "единиц", "unit", "од."])
        if col_name is None:
            raise ValueError("Колонка 'Номенклатура' не знайдена")      # спровокувати помилку
        items = []
        found_header = False
        for row in ws.iter_rows(values_only=True):
            row_vals = [str(c).strip() if c is not None else "" for c in row]
            if not found_header:
                if any("номенклатур" in v.lower() for v in row_vals):
                    found_header = True
                continue                                                # перейти до наступного
            name_val = row_vals[col_name] if col_name < len(row_vals) else ""
            if not name_val or name_val.lower() in ("разом", "итого", "всего", "total"):
                continue                                                # перейти до наступного
            def safe_float(idx):
                if idx is None or idx >= len(row_vals): return 0.0      # вийти з методу
                v = row_vals[idx].replace(" ", "").replace(",", ".")
                try: return float(v)                                    # вийти з методу
                except: return 0.0                                      # вийти з методу
            items.append({
                "name":        name_val,
                "end_stock":   safe_float(col_end),
                "start_stock": safe_float(col_start),
                "income":      safe_float(col_income),
                "expense":     safe_float(col_expense),
                "unit":        row_vals[col_unit] if col_unit and col_unit < len(row_vals) else "шт",
            })
        return items                                                    # вийти з методу

    def _parse_1c_csv_rows(self, rows):
        header_idx = None
        header_row = None
        for i, row in enumerate(rows):
            row_s = [c.strip() for c in row]
            if any("номенклатур" in c.lower() for c in row_s):
                header_idx = i
                header_row = row_s
                break
        if header_row is None:
            raise ValueError("Не знайдено рядок 'Номенклатура'")        # спровокувати помилку
        def find_col(keywords):
            for i, h in enumerate(header_row):
                if any(k in h.lower() for k in keywords): return i      # вийти з методу
            return None                                                 # вийти з методу
        col_name    = find_col(["номенклатур"])
        col_end     = find_col(["кінець", "конец", "end"])
        col_start   = find_col(["початок", "начало", "start"])
        col_income  = find_col(["прихід", "приход", "income"])
        col_expense = find_col(["розхід", "расход", "expense"])
        col_unit    = find_col(["одиниц", "единиц", "unit"])
        items = []
        for row in rows[header_idx + 1:]:
            row_s = [c.strip() for c in row]
            if not row_s: continue                                      # перейти до наступного
            name_val = row_s[col_name] if col_name is not None and col_name < len(row_s) else ""
            if not name_val or name_val.lower() in ("разом", "итого", "total"): continue # перейти до наступного
            def safe_float(idx):
                if idx is None or idx >= len(row_s): return 0.0         # вийти з методу
                v = row_s[idx].replace(" ", "").replace(",", ".")
                try: return float(v)                                    # вийти з методу
                except: return 0.0                                      # вийти з методу
            items.append({
                "name":        name_val,
                "end_stock":   safe_float(col_end),
                "start_stock": safe_float(col_start),
                "income":      safe_float(col_income),
                "expense":     safe_float(col_expense),
                "unit":        row_s[col_unit] if col_unit and col_unit < len(row_s) else "шт",
            })
        return items                                                    # вийти з методу

