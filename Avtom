    def _update_clock(self):
        self._clock_lbl.config(text=datetime.now().strftime("%H:%M:%S   %d.%m.%Y"))
        self.root.after(1000, self._update_clock)

    def _status(self, msg, color=None):
        self._status_var.set(msg)
        if color:
            self._status_lbl.config(fg=color)
        else:
            self._status_lbl.config(fg=C["text3"])

    def _toggle_auto_refresh(self):
        self._auto_refresh = not self._auto_refresh                     # переключити стан
        if self._auto_refresh:                                          # якщо увімкнено
            self._auto_btn_text.set(self.T_("autoupdate_on"))
            self._auto_indicator.config(text="● LIVE", fg=C["success"])
            self._auto_refresh_tick()                                   # запустити тік
        else:
            self._auto_btn_text.set(self.T_("autoupdate_off"))
            self._auto_indicator.config(text="⏸ PAUSED", fg=C["text3"])
            if self._auto_refresh_id:                                   # якщо є активний таймер
                self.root.after_cancel(self._auto_refresh_id)           # скасувати таймер

    def _auto_refresh_tick(self):
        if not self._auto_refresh:                                      # якщо вимкнено - вийти
            return                                                      # вийти з методу
        # Перевіряємо чи є нові рухи (без перезавантаження якщо нічого не змінилось)
        cur_count = len(self.model.data["movements"])                   # поточна кількість операцій
        if cur_count != self._last_mov_count:                           # якщо щось змінилось
            self._last_mov_count = cur_count                            # оновити лічильник
            self._silent_refresh()                                      # тихо оновити вкладки
        self._auto_refresh_id = self.root.after(5000, self._auto_refresh_tick) # перший тік автооновлення через 5с

    def _silent_refresh(self):
        """Тихе оновлення без зміни статусу."""
        try:
            self.refresh_dashboard()                                    # оновити дашборд
            self._load_movements()                                      # перезавантажити таблицю рухів
            self._refresh_stock_tab()                                   # перезавантажити залишки
        except Exception:
            pass

