    def _apply_theme_to_all_widgets(self, widget):
        """Рекурсивно переофарблює всі tk-віджети під поточну тему C."""
        cls = widget.winfo_class()                                      # клас віджету
        try:
            if cls in ("Frame", "Labelframe"):                          # фрейм
                widget.configure(bg=C["bg"])                            # встановити фон
            elif cls == "Label":                                        # мітка
                widget.configure(bg=C["bg"], fg=C["text"])              # фон і колір тексту
            elif cls == "Canvas":                                       # полотно
                widget.configure(bg=C["canvas_bg"])                     # фон полотна
            elif cls == "Text":                                         # текстове поле
                widget.configure(bg=C["canvas_bg"], fg=C["text"],
                                  insertbackground=C["text"])
            elif cls == "Button":                                       # звичайна кнопка
                widget.configure(bg=C["bg3"], fg=C["text"],
                                  activebackground=C["border2"])
        except Exception:
            pass
        for child in widget.winfo_children():                           # рекурсія по дочірніх
            self._apply_theme_to_all_widgets(child)                     # застосувати тему до дочірнього
        # Оновити ttk-стилі
        self._setup_styles()                                            # налаштувати стилі ttk
        # Оновити фони хедера і статусбара
        try:
            for w in self.root.winfo_children():
                if isinstance(w, tk.Frame) and w.winfo_height() <= 60:
                    try: w.configure(bg=C["accent_dk"])
                    except: pass
        except Exception:
            pass
        # Оновити дані у всіх табах
        self.root.after(50, self._full_refresh)                         # оновити всі вкладки через 50мс

    # Привязка гарячих клавіш
    # Ctrl+N - нова операція, F5 - повне оновлення,
    # Ctrl+E - перехід до експорту, Ctrl+R - редагування залишку,
    # Ctrl+F - пошук у довіднику. Також перевизначені Ctrl+C/V/A для коректної
    # роботи з полями вводу в середовищі tkinter.
    def _bind_hotkeys(self):
        self.root.bind("<Control-n>", lambda _: (self.nb.select(1), self._mv_qty.focus())) # встановити фокус на кількість
        self.root.bind("<F5>",        lambda _: self._full_refresh())
        self.root.bind("<Control-e>", lambda _: self.nb.select(5))
        self.root.bind("<Control-r>", lambda _: (self.nb.select(3), self._edit_stock_dialog()))
        self.root.bind("<Control-f>", lambda _: (self.nb.select(2), self._pd_search_var.set("")))

        def _on_copy(event):
            w = self.root.focus_get()
            if w and hasattr(w, "selection_get"):
                try:
                    text = w.selection_get()
                    self.root.clipboard_clear(); self.root.clipboard_append(text)
                except Exception: pass                                  # ігнорувати якщо вкладка ще не готова
            return "break"                                              # вийти з методу

        def _on_paste(event):
            w = self.root.focus_get()
            if w is None: return                                        # вийти з методу
            try: text = self.root.clipboard_get()
            except: return                                              # вийти з методу
            if isinstance(w, tk.Text):
                try: w.delete(tk.SEL_FIRST, tk.SEL_LAST)
                except: pass
                w.insert(tk.INSERT, text)
            elif hasattr(w, "insert") and hasattr(w, "index"):
                try: w.delete(tk.SEL_FIRST, tk.SEL_LAST)
                except: pass
                try: w.insert(w.index(tk.INSERT), text)
                except: pass
            return "break"                                              # вийти з методу

        def _on_select_all(event):
            w = self.root.focus_get()
            if w is None: return                                        # вийти з методу
            if isinstance(w, tk.Text):
                w.tag_add(tk.SEL, "1.0", tk.END)
            elif hasattr(w, "select_range"):
                try: w.select_range(0, tk.END); w.icursor(tk.END)
                except: pass
            return "break"                                              # вийти з методу

        self.root.bind_all("<Control-c>", _on_copy)
        self.root.bind_all("<Control-v>", _on_paste)
        self.root.bind_all("<Control-a>", _on_select_all)

