    def _load_movements(self, movements=None):
        self._mv_tree.delete(*self._mv_tree.get_children())             # очистити таблицю
        if movements is None:                                           # якщо не передали список
            movements = self.model.data.get("movements", []) # взяти всі операції з моделі
        running = {}                                                    # поточний залишок по кожному товару
        sorted_movs = sorted(movements, key=lambda x: (x["date"], x["time"])) # сортувати за датою і часом
        for idx, m in enumerate(sorted_movs):                           # перебрати відсортовані операції
            n = m["product"]                                            # назва товару
            running.setdefault(n, 0.0)                                  # ініціалізувати якщо вперше
            if m["type"] == DataModel.TYPE_INCOME:                      # прихід
                running[n] += m["qty"]                                  # збільшити поточний залишок
            else:
                running[n] -= m["qty"]                                  # зменшити поточний залишок
            tag_type = {                                                # визначити тег кольору рядка
                DataModel.TYPE_INCOME:   "income",
                DataModel.TYPE_EXPENSE:  "expense",
                DataModel.TYPE_WRITEOFF: "writeoff",
            }.get(m["type"], "expense")
            tags = (tag_type, "alt") if idx % 2 == 0 else (tag_type,)   # чергування фону рядків
            self._mv_tree.insert("", "end", values=( # додати рядок до таблиці
                m["id"],
                m["date"],
                m["time"],
                m["product"],
                self._type_label(m["type"]),
                m["qty"],
                round(running[n], 2),                                   # залишок після операції
                m.get("comment", "")                                    # коментар або порожній рядок
            ), tags=tags)                                               # застосувати теги кольору
        self._mv_count_lbl.config(text=f"{self.T_('records')} {len(movements)}") # оновити лічильник записів

    def _add_movement(self):
        prod  = self._mv_prod.get().strip()                             # назва товару з поля вводу
        qty_s = self._mv_qty.get().strip()                              # кількість як рядок
        if not prod or not qty_s:                                       # якщо поля порожні
            messagebox.showwarning(self.T_("warning_title"), self.T_("warn_fill")) # показати попередження
            return                                                      # вийти з методу
        try:
            qty = float(qty_s)                                          # перетворити в число
            if qty <= 0:                                                # перевірити що > 0
                raise ValueError                                        # спровокувати помилку
        except ValueError:
            messagebox.showerror(self.T_("error_title"), self.T_("err_qty")) # показати помилку
            return                                                      # вийти з методу

        # Якщо товар з таким найменуванням ще не існує в довіднику -
        # він автоматично створюється з базовими параметрами.
        # Це дозволяє реєструвати операції без попереднього налаштування довідника.
        existing_names = [p["name"] for p in self.model.data["products"]] # список назв товарів
        if prod not in existing_names:                                  # якщо товару немає в довіднику
            new_id = max((p["id"] for p in self.model.data["products"]), default=0) + 1 # наступний ID товару
            new_p = {                                                   # новий запис товару
                "id": new_id, "name": prod,                             # унікальний номер запису
                "unit": self.T_("pcs"), "category": "",                 # одиниця виміру за замовч.
                "min_stock": 5, "daily_consumption": 1.0,               # мінімальний запас 5
                "monthly_consumption": 30.0, "delivery_days": 7,        # витрата 30 на місяць
                "safety_stock": self.model.calc_safety_stock(1.0, 7),   # розрахувати страховий запас
            }
            self.model.data["products"].append(new_p)                   # додати товар до довідника
            self.model._audit("AUTO_ADD_PROD", f"Автостворено: {prod}") # записати автостворення в аудит
            self._update_product_combos()                               # оновити списки вибору товарів
            self._status(f"📦 Товар «{prod}» автоматично додано до довідника", C["warning"])

        sel_label = self._mv_type.get()                                 # обраний тип операції
        mov_type = self._type_from_label(sel_label)                     # конвертувати в внутрішній код
        self.model.add_movement(prod, mov_type, qty, self._mv_cmt.get()) # зберегти операцію
        self._last_mov_count = len(self.model.data["movements"])        # оновити лічильник
        self._load_movements()                                          # перезавантажити таблицю рухів
        self._refresh_stock_tab()                                       # перезавантажити залишки
        self._load_products()                                           # оновити довідник
        self.refresh_dashboard()                                        # оновити дашборд
        self._status(f"✅ {self._type_label(mov_type)}: {prod} × {qty}", C["success"])
        self._mv_qty.delete(0, "end") # очистити поле кількості
        self._mv_cmt.delete(0, "end") # очистити поле коментаря
        self._mv_qty.focus()                                            # встановити фокус на кількість

    def _apply_filters(self):
        df  = self._f_df.get().strip()                                  # дата від
        dt  = self._f_dt.get().strip()                                  # дата до
        prod= self._f_prod.get().strip()                                # фільтр по товару
        typ_sel = self._f_typ.get().strip()                             # фільтр по типу
        srch = self._mv_search_var.get().strip().lower()                # пошуковий рядок

        typ_filter = ""                                                 # початково без фільтру типу
        if typ_sel and typ_sel != self.T_("lbl_all"):                   # якщо обрано конкретний тип
            typ_filter = self._type_from_label(typ_sel)                 # конвертувати в код

        result = []                                                     # список відфільтрованих
        for m in self.model.data.get("movements", []): # перебрати всі операції
            if df and m["date"] < df:                                   # пропустити якщо раніше дати від
                continue                                                # перейти до наступного
            if dt and m["date"] > dt:                                   # пропустити якщо пізніше дати до
                continue                                                # перейти до наступного
            if prod and prod != self.T_("lbl_all") and m["product"] != prod: # фільтр по товару
                continue                                                # перейти до наступного
            if typ_filter and m["type"] != typ_filter:                  # фільтр по типу
                continue                                                # перейти до наступного
            if srch:                                                    # якщо є пошуковий рядок
                searchable = f"{m['product']} {self._type_label(m['type'])} {m.get('comment','')}".lower() # рядок для пошуку
                if srch not in searchable:                              # якщо не збігається
                    continue                                            # перейти до наступного
            result.append(m)                                            # додати до результату

        self._load_movements(result)                                    # відобразити відфільтровані
        self._status(self.T_("filter_result", len(result))) # показати кількість знайдених

    def _reset_filters(self):
        self._f_df.delete(0, "end")
        self._f_df.insert(0, (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d"))
        self._f_dt.delete(0, "end")
        self._f_dt.insert(0, datetime.now().strftime("%Y-%m-%d"))
        self._f_prod.set(self.T_("lbl_all"))
        self._f_typ.set(self.T_("lbl_all"))
        self._mv_search_var.set("")
        self._load_movements()                                          # перезавантажити таблицю рухів
        self._status(self.T_("filters_reset"))

    def _edit_movement(self):
        sel = self._mv_tree.selection()                                 # виділені рядки таблиці
        if not sel:                                                     # якщо нічого не виділено
            messagebox.showwarning(self.T_("warning_title"), self.T_("warn_sel")) # показати попередження
            return                                                      # вийти з методу
        mid = self._mv_tree.item(sel[0])["values"][0]
        mov = next((m for m in self.model.data["movements"] if m["id"] == mid), None)
        if mov:
            self._open_mov_dialog(mov)

    def _open_mov_dialog(self, mov):
        dlg = tk.Toplevel(self.root)
        dlg.title(self.T_("edit_movement"))
        dlg.geometry("500x280")
        dlg.configure(bg=C["bg"])
        dlg.transient(self.root)
        dlg.grab_set()
        dlg.resizable(False, False)

        tk.Label(dlg, text=f"✏️ {self.T_('edit_movement')}",
                  bg=C["bg"], fg=C["text"], font=FNTH).pack(pady=(16, 12))
        frm = tk.Frame(dlg, bg=C["bg"])
        frm.pack(padx=24, fill="x")
        prod_names = [p["name"] for p in self.model.data["products"]]   # список назв товарів
        type_labels = [self.T_("lbl_income"), self.T_("lbl_expense"), self.T_("lbl_writeoff")]
        ws = {}
        fields = [
            (self.T_("lbl_product"), "product", "combo_product"),
            (self.T_("lbl_type"),    "type",    "combo_type"),
            (self.T_("lbl_qty"),     "qty",     "entry"),
            (self.T_("lbl_comment"), "comment", "entry"),
        ]
        for i, (lbl, key, wtype) in enumerate(fields):
            ttk.Label(frm, text=lbl + ":").grid(row=i, column=0, sticky="e", padx=(0, 10), pady=7)
            if wtype == "combo_product":
                w = ttk.Combobox(frm, values=prod_names, width=36)
                w.set(mov[key])
            elif wtype == "combo_type":
                w = ttk.Combobox(frm, values=type_labels, width=36, state="readonly")
                w.set(self._type_label(mov[key]))
            else:
                w = ttk.Entry(frm, width=38)
                w.insert(0, str(mov[key]))
            w.grid(row=i, column=1, sticky="ew", pady=7)
            ws[key] = w

        def save():
            try:
                qty = float(ws["qty"].get())
                if qty <= 0:                                            # перевірити що > 0
                    raise ValueError                                    # спровокувати помилку
            except ValueError:
                messagebox.showerror(self.T_("error_title"), self.T_("err_qty")) # показати помилку
                return                                                  # вийти з методу
            mov.update({
                "product": ws["product"].get(),
                "type":    self._type_from_label(ws["type"].get()),
                "qty":     qty,
                "comment": ws["comment"].get()
            })
            self.model._audit("EDIT_MOV", f"#{mov['id']}")
            self.model.save()                                           # зберегти дані перед виходом
            self._load_movements()                                      # перезавантажити таблицю рухів
            self._refresh_stock_tab()                                   # перезавантажити залишки
            self.refresh_dashboard()                                    # оновити дашборд
            dlg.destroy()                                               # закрити діалог
            self._status(self.T_("movement_updated", mov["id"]), C["success"])

        br = tk.Frame(dlg, bg=C["bg"])
        br.pack(pady=14)
        ttk.Button(br, text=self.T_("btn_save"),   style="Accent.TButton", command=save).pack(side="left", padx=6)
        ttk.Button(br, text=self.T_("btn_cancel"), command=dlg.destroy).pack(side="left", padx=6)

    def _delete_movement(self):
        sel = self._mv_tree.selection()                                 # виділені рядки таблиці
        if not sel:                                                     # якщо нічого не виділено
            return                                                      # вийти з методу
        ids = [self._mv_tree.item(s)["values"][0] for s in sel]         # ID виділених записів
        if not messagebox.askyesno(self.T_("confirm_title"), self.T_("confirm_del", len(ids))): # запитати підтвердження
            return                                                      # вийти з методу
        self.model.data["movements"] = [m for m in self.model.data["movements"] if m["id"] not in ids] # видалити з списку
        self.model._audit("DELETE_MOV", f"IDs: {ids}") # записати видалення в аудит
        self.model.save()                                               # зберегти дані перед виходом
        self._last_mov_count = len(self.model.data["movements"])        # оновити лічильник
        self._load_movements()                                          # перезавантажити таблицю рухів
        self._refresh_stock_tab()                                       # перезавантажити залишки
        self.refresh_dashboard()                                        # оновити дашборд
        self._status(self.T_("deleted", len(ids)))

    def _refresh_movements(self):
        self._load_movements()                                          # перезавантажити таблицю рухів
        self._status(self.T_("updated"))

    def _copy_mv_row(self):
        sel = self._mv_tree.selection()                                 # виділені рядки таблиці
        if not sel:                                                     # якщо нічого не виділено
            return                                                      # вийти з методу
        rows = ["\t".join(str(v) for v in self._mv_tree.item(s)["values"]) for s in sel]
        self.root.clipboard_clear()
        self.root.clipboard_append("\n".join(rows))
        self._status(self.T_("copied", len(rows)))

    def _import_excel(self):
        path = filedialog.askopenfilename(
            title=self.T_("import_title"),
            filetypes=[("Excel", "*.xlsx *.xls"), ("All", "*.*")])
        if not path:
            return                                                      # вийти з методу
        try:
            count = self.model.import_from_excel(path)
            self._last_mov_count = len(self.model.data["movements"])    # оновити лічильник
            self._load_movements()                                      # перезавантажити таблицю рухів
            self._refresh_stock_tab()                                   # перезавантажити залишки
            self.refresh_dashboard()                                    # оновити дашборд
            messagebox.showinfo(self.T_("done_title"), self.T_("import_success", count))
            self._status(self.T_("import_success", count), C["success"])
        except Exception as e:
            messagebox.showerror(self.T_("error_title"), self.T_("import_error", str(e))) # показати помилку

