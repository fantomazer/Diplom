        # Панель дій розміщена під таблицею в коді, але відображається після неї
        # Через те що pack вже зробив pack таблиці, додаємо кнопки нижче але стилізуємо як toolbar
        tb = tk.Frame(parent, bg=C["bg2"],
                      highlightthickness=1, highlightbackground=C["border"])
        tb.pack(fill="x", padx=10, pady=(0, 2))
        tb_left = tk.Frame(tb, bg=C["bg2"]); tb_left.pack(side="left", padx=6, pady=5)
        ttk.Button(tb_left, text=self.T_("btn_add"),    command=self._add_product,
                    style="Accent.TButton").pack(side="left", padx=2)
        ttk.Button(tb_left, text=self.T_("btn_edit"),   command=self._edit_product_dialog).pack(side="left", padx=2)
        ttk.Button(tb_left, text=self.T_("btn_delete"), command=self._delete_product,
                    style="Danger.TButton").pack(side="left", padx=2)
        ttk.Button(tb_left, text=self.T_("recalc"),     command=self._recalc_safety).pack(side="left", padx=2)
        self._pd_count_lbl = ttk.Label(tb_left, text="", font=FNTS, foreground=C["text3"])
        self._pd_count_lbl.pack(side="left", padx=14)
        tb_right = tk.Frame(tb, bg=C["bg2"]); tb_right.pack(side="right", padx=6, pady=5)
        ttk.Button(tb_right, text=self.T_("btn_excel"), command=self._export_products_excel).pack(side="right", padx=2)
        self._load_products()                                           # оновити довідник

    def _load_products(self):
        self._pd_tree.delete(*self._pd_tree.get_children())             # очистити таблицю довідника
        stocks = self.model.get_stocks()                                # отримати залишки
        STATUS_CFG = self._get_status_cfg()                             # конфіги статусів
        search = self._pd_search_var.get().strip().lower() if hasattr(self, "_pd_search_var") else "" # пошуковий рядок
        count = 0                                                       # лічильник відображених
        for idx, p in enumerate(self.model.data["products"]):           # перебрати товари
            if search and search not in p["name"].lower() and search not in p.get("category", "").lower(): # фільтр пошуку
                continue                                                # перейти до наступного
            cur = stocks.get(p["name"], 0.0)                     # поточний залишок товару
            status = self.model.get_status(p, cur)                      # статус
            rp = self.model.get_reorder_point(p)                        # точка замовлення
            dl = self.model.get_days_left(p, cur)                       # днів залишилось
            cfg = STATUS_CFG[status]                                    # конфіг поточного статусу
            tags = (status, "alt") if idx % 2 == 0 else (status,)       # теги для кольору рядка
            self._pd_tree.insert("", "end", values=(
                p["id"], p["name"], p.get("unit", self.T_("pcs")),
                p.get("category", ""), p["min_stock"],
                p["daily_consumption"], p["monthly_consumption"],
                p["delivery_days"], p["safety_stock"], rp, cur, dl,
                f"{cfg['icon']} {cfg['label']}"
            ), tags=tags)                                               # застосувати теги кольору
            count += 1                                                  # збільшити лічильник
        if hasattr(self, "_pd_count_lbl"):                              # якщо мітка лічильника існує
            self._pd_count_lbl.config(text=f"{self.T_('records')} {count}") # оновити лічильник

    def _add_product(self):
        self._product_dialog(None)

    def _edit_product_dialog(self):
        sel = self._pd_tree.selection()
        if not sel:                                                     # якщо нічого не виділено
            messagebox.showwarning(self.T_("warning_title"), self.T_("warn_sel_p")) # показати попередження
            return                                                      # вийти з методу
        pid = self._pd_tree.item(sel[0])["values"][0]
        p = next((x for x in self.model.data["products"] if x["id"] == pid), None)
        if p:
            self._product_dialog(p)

    def _product_dialog(self, product):
        is_new = product is None
        dlg = tk.Toplevel(self.root)
        dlg.title(self.T_("add_product") if is_new else self.T_("edit_product"))
        dlg.geometry("500x400")
        dlg.configure(bg=C["bg"])
        dlg.transient(self.root)
        dlg.grab_set()
        dlg.resizable(False, False)

        title = f"➕ {self.T_('new_product')}" if is_new else f"✏️ {self.T_('edit_product')}: {product['name']}"
        tk.Label(dlg, text=title, bg=C["bg"], fg=C["text"], font=FNTH).pack(pady=(16, 12))

        frm = tk.Frame(dlg, bg=C["bg"])
        frm.pack(padx=24, fill="x")
        frm.columnconfigure(1, weight=1)

        fields = [
            (self.T_("col_name"),      "name",               ""),
            (self.T_("unit"),          "unit",               self.T_("pcs")),
            (self.T_("col_category"),  "category",           ""),
            (self.T_("min_stock"),     "min_stock",          "10"),
            (self.T_("daily_cons"),    "daily_consumption",  "1.0"),
            (self.T_("monthly_cons"),  "monthly_consumption","30"),
            (self.T_("delivery_days"), "delivery_days",      "7"),
        ]
        entries = {}
        hints = {
            "name":               "Повне найменування товару",
            "unit":               "Наприклад: шт, кг, пач, л",
            "category":           "Наприклад: Канцелярія, Техніка",
            "min_stock":          "Мінімально допустимий залишок",
            "daily_consumption":  "Середня витрата за 1 день",
            "monthly_consumption":"Середня витрата за місяць",
            "delivery_days":      "Скільки днів чекати постачання",
        }
        for i, (lbl, key, default) in enumerate(fields):
            ttk.Label(frm, text=lbl + ":").grid(row=i, column=0, sticky="e", padx=(0, 10), pady=6)
            w = ttk.Entry(frm, width=38)
            w.grid(row=i, column=1, sticky="ew", pady=6)
            if not is_new:
                w.insert(0, str(product.get(key, default)))
            elif default:
                w.insert(0, default)
            entries[key] = w
            Tooltip(w, hints.get(key, ""))

        def save():
            try:
                name = entries["name"].get().strip()                    # назва товару з форми
                if not name:                                            # якщо порожнє - помилка
                    raise ValueError(self.T_("err_name"))               # спровокувати помилку
                daily    = float(entries["daily_consumption"].get())    # денна витрата
                delivery = int(entries["delivery_days"].get())          # термін доставки
                monthly  = float(entries["monthly_consumption"].get())  # місячна витрата
                min_st   = int(entries["min_stock"].get())              # мінімальний запас
                if daily < 0 or delivery < 0 or monthly < 0 or min_st < 0: # перевірка на від'ємні
                    raise ValueError("Значення не можуть бути від'ємними") # спровокувати помилку
            except ValueError as e:
                messagebox.showerror(self.T_("error_title"), str(e))    # показати помилку
                return                                                  # вийти з методу
            safety = self.model.calc_safety_stock(daily, delivery)      # розрахувати страховий запас
            if is_new:                                                  # якщо це новий товар
                new_id = max((p["id"] for p in self.model.data["products"]), default=0) + 1 # наступний ID товару
                p = {
                    "id": new_id, "name": name,                         # унікальний номер запису
                    "unit":     entries["unit"].get().strip() or self.T_("pcs"),
                    "category": entries["category"].get().strip(),
                    "min_stock": min_st, "daily_consumption": daily,
                    "monthly_consumption": monthly, "delivery_days": delivery,
                    "safety_stock": safety
                }
                self.model.data["products"].append(p)                   # додати в довідник
                self.model._audit("ADD_PROD", name)                     # записати в аудит
            else:
                product.update({                                        # оновити запис що вже існує
                    "name": name,
                    "unit":     entries["unit"].get().strip() or self.T_("pcs"),
                    "category": entries["category"].get().strip(),
                    "min_stock": min_st, "daily_consumption": daily,
                    "monthly_consumption": monthly, "delivery_days": delivery,
                    "safety_stock": safety
                })
                self.model._audit("EDIT_PROD", name) # записати редагування в аудит
            self.model.save()                                           # зберегти дані перед виходом
            self._load_products()                                       # оновити довідник
            self._update_product_combos()                               # оновити списки вибору товарів
            self.refresh_dashboard()                                    # оновити дашборд
            dlg.destroy()                                               # закрити діалог
            self._status(self.T_("product_added" if is_new else "product_updated", name), C["success"])

        br = tk.Frame(dlg, bg=C["bg"])
        br.pack(pady=14)
        ttk.Button(br, text=self.T_("btn_save"),   style="Accent.TButton", command=save).pack(side="left", padx=6)
        ttk.Button(br, text=self.T_("btn_cancel"), command=dlg.destroy).pack(side="left", padx=6)
        entries["name"].focus()

    def _delete_product(self):
        sel = self._pd_tree.selection()
        if not sel:                                                     # якщо нічого не виділено
            return                                                      # вийти з методу
        vals = self._pd_tree.item(sel[0])["values"]
        name = vals[1]
        if messagebox.askyesno(self.T_("confirm_title"), self.T_("confirm_del_p", name)):
            self.model.data["products"] = [p for p in self.model.data["products"] if p["id"] != vals[0]]
            self.model._audit("DELETE_PROD", name)
            self.model.save()                                           # зберегти дані перед виходом
            self._load_products()                                       # оновити довідник
            self._update_product_combos()                               # оновити списки вибору товарів
            self.refresh_dashboard()                                    # оновити дашборд
            self._status(self.T_("product_deleted", name))

    def _recalc_safety(self):
        for p in self.model.data["products"]:                           # перебрати всі товари
            p["safety_stock"] = self.model.calc_safety_stock(           # перерахувати страховий запас
                p["daily_consumption"], p["delivery_days"])
        self.model.save()                                               # зберегти дані перед виходом
        self._load_products()                                           # оновити довідник
        self._status(self.T_("safety_recalc"), C["success"])

    # Вкладка "Залишки"
    # Зведена таблиця поточних залишків з відображенням статусу кожного товару,
    # кількості днів запасу та рекомендованого обсягу замовлення.
    def _build_stock(self, parent):
        # Панель дій будується першою - відображається над таблицею
        tb = tk.Frame(parent, bg=C["bg2"],
                      highlightthickness=1, highlightbackground=C["border"])
        tb.pack(fill="x", padx=10, pady=(8, 2))
        tb_left = tk.Frame(tb, bg=C["bg2"]); tb_left.pack(side="left", padx=6, pady=5)
        # кнопки будуть привязані нижче, після створення tree - зберігаємо посилання через лямбди
        self._st_btn_frame = tb_left
        tb_right = tk.Frame(tb, bg=C["bg2"]); tb_right.pack(side="right", padx=6, pady=5)
        self._st_btn_right = tb_right

        tk.Label(parent, text=self.T_("stock_tab_hint"),
                  bg=C["bg"], fg=C["text3"], font=FNTS).pack(anchor="w", padx=12, pady=(2, 2))
        tf = tk.Frame(parent, bg=C["bg"])
        tf.pack(fill="both", expand=True, padx=10, pady=(0, 4))
        cols = ("name", "unit", "category", "current", "min_stock",
                "safety", "reorder", "days_left", "order_qty", "status")
