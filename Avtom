# Клас моделі даних
# Відповідає за зберігання, завантаження та обробку всіх даних системи:
# довідника товарів, журналу операцій та журналу аудиту.
# Реалізує бізнес-логіку: розрахунок залишків, статусів, точок замовлення,
# страхових запасів за методом Safety Stock (формула з коефіцієнтом варіації).
class DataModel:

    # Внутрішні коди типів операцій - не залежать від обраної мови інтерфейсу.
    # Це дозволяє зберігати дані в одному форматі незалежно від локалізації.
    TYPE_INCOME   = "income"    # прихід товару на склад
    TYPE_EXPENSE  = "expense"   # витрата (відпуск) товару зі складу
    TYPE_WRITEOFF = "writeoff"  # списання (втрати, брак)

    def __init__(self):
        # Початкова структура даних. При першому запуску заповнюється демонстраційними даними.
        self.data = {"products": [], "movements": [], "audit": []}      # початкова структура трьох колекцій
        self._load()                                                    # завантажити дані з диска

    def _load(self):
        # Завантаження даних з JSON-файлу. Якщо файл відсутній або пошкоджений -
        # генеруються демонстраційні дані для наочності роботи системи.
        if os.path.exists(DATA_FILE):                                   # перевірити чи є файл даних
            try:
                with open(DATA_FILE, "r", encoding="utf-8") as f:       # відкрити файл для читання
                    d = json.load(f)                                    # розпарсити JSON
                    self.data["products"]  = d.get("products", [])      # завантажити товари
                    self.data["movements"] = d.get("movements", [])     # завантажити операції
                    self.data["audit"]     = d.get("audit", [])         # завантажити аудит
                # Конвертація типів зі старого формату (текстовий) в новий (код)
                self._migrate_types()                                   # конвертувати старий формат типів
            except Exception:
                self._init_demo()                                       # згенерувати демо-дані
        else:
            self._init_demo()                                           # згенерувати демо-дані

    def _migrate_types(self):
        # Забезпечення зворотної сумісності з даними попередніх версій програми.
        # Старі записи зберігали тип операції як локалізований рядок ("Приход", "Расход" тощо).
        # Нова версія використовує мовонезалежні внутрішні коди.
        mapping = {
            "Приход": self.TYPE_INCOME, "Прихід": self.TYPE_INCOME, "Income": self.TYPE_INCOME,
            "Расход": self.TYPE_EXPENSE, "Витрата": self.TYPE_EXPENSE, "Expense": self.TYPE_EXPENSE,
            "Списание": self.TYPE_WRITEOFF, "Списання": self.TYPE_WRITEOFF, "Write-off": self.TYPE_WRITEOFF,
        }
        changed = False                                                 # прапорець чи були зміни
        for m in self.data["movements"]:                                # обійти всі операції
            old = m.get("type", "")                                     # старий тип операції
            if old in mapping:                                          # якщо тип потребує конвертації
                m["type"] = mapping[old]                                # замінити на новий код
                changed = True                                          # відмітити що були зміни
        if changed:                                                     # якщо щось змінилось - зберегти
            self.save()                                                 # зберегти на диск

    def save(self):
        # Збереження даних у JSON-файл з автоматичним створенням резервної копії.
        # Зберігається не більше 10 останніх резервних копій, старі видаляються.
        if os.path.exists(DATA_FILE):                                   # перевірити чи є файл даних
            os.makedirs(BACKUP_DIR, exist_ok=True)                      # створити папку бекапів якщо нема
            ts = datetime.now().strftime("%Y%m%d_%H%M%S")               # мітка часу для імені бекапу
            shutil.copy2(DATA_FILE, os.path.join(BACKUP_DIR, f"backup_{ts}.json")) # скопіювати поточний файл як бекап
            bks = sorted(os.listdir(BACKUP_DIR))                        # список всіх бекапів за іменем
            for old in bks[:-10]:                                       # залишити лише 10 останніх
                os.remove(os.path.join(BACKUP_DIR, old))                # видалити старий бекап
        with open(DATA_FILE, "w", encoding="utf-8") as f:               # відкрити файл для запису
            json.dump(self.data, f, ensure_ascii=False, indent=2)       # записати дані як JSON

    def _init_demo(self):
        # Генерація демонстраційного набору даних для першого запуску.
        # Містить 6 типових товарів офісного складу та змодельовані операції
        # за останні 45 днів з випадковими обсягами витрат.
        demo = [
            {"id":1,"name":"Картридж HP LaserJet","min_stock":5,"daily_consumption":0.5,"monthly_consumption":15,"delivery_days":7,"safety_stock":0,"unit":"шт","category":"Витратники"},
            {"id":2,"name":"Папір А4 (пачка 500 арк)","min_stock":10,"daily_consumption":2,"monthly_consumption":60,"delivery_days":5,"safety_stock":0,"unit":"пач","category":"Канцелярія"},
            {"id":3,"name":"Ручки кулькові сині","min_stock":50,"daily_consumption":5,"monthly_consumption":150,"delivery_days":3,"safety_stock":0,"unit":"шт","category":"Канцелярія"},
            {"id":4,"name":"Ноутбук Dell Latitude","min_stock":2,"daily_consumption":0.1,"monthly_consumption":3,"delivery_days":14,"safety_stock":0,"unit":"шт","category":"Техніка"},
            {"id":5,"name":"Тонер Canon 054H","min_stock":3,"daily_consumption":0.3,"monthly_consumption":9,"delivery_days":6,"safety_stock":0,"unit":"шт","category":"Витратники"},
            {"id":6,"name":"Папка-реєстратор А4","min_stock":20,"daily_consumption":1,"monthly_consumption":30,"delivery_days":4,"safety_stock":0,"unit":"шт","category":"Канцелярія"},
        ]
        for p in demo:
            p["safety_stock"] = self.calc_safety_stock(p["daily_consumption"], p["delivery_days"])
        self.data["products"] = demo
        random.seed(42)
        movs, mid = [], 1
        for p in demo:
            # Початковий залишок
            movs.append({
                "id": mid, "product": p["name"],
                "date": (datetime.now()-timedelta(days=45)).strftime("%Y-%m-%d"),
                "time": "08:00:00", "type": self.TYPE_INCOME,
                "qty": p["min_stock"] * 8, "comment": "Початковий залишок"
            })
            mid += 1
            # Операції за останні 30 днів
            for d in range(1, 31, 2):
                qty = round(p["daily_consumption"] * random.uniform(0.8, 1.4) * 2, 1)
                if qty > 0:
                    movs.append({
                        "id": mid, "product": p["name"],
                        "date": (datetime.now()-timedelta(days=d)).strftime("%Y-%m-%d"),
                        "time": f"{random.randint(9,17):02d}:{random.randint(0,59):02d}:00",
                        "type": self.TYPE_EXPENSE, "qty": qty, "comment": "" # кількість
                    })
                    mid += 1
            # Один прихід
            movs.append({
                "id": mid, "product": p["name"],
                "date": (datetime.now()-timedelta(days=15)).strftime("%Y-%m-%d"),
                "time": "10:00:00", "type": self.TYPE_INCOME,
                "qty": p["min_stock"] * 4, "comment": "Планове поповнення"
            })
            mid += 1
        self.data["movements"] = movs
        self.save()                                                     # зберегти на диск

    @staticmethod
    def calc_safety_stock(daily, delivery, cv=0.3):
        # Розрахунок страхового (буферного) запасу за статистичним методом.
        # Формула: SS = Z * CV * d * sqrt(L)
        # де Z = 1.65 - квантиль нормального розподілу для рівня обслуговування 95%,
        #     CV - коефіцієнт варіації попиту (відношення стандартного відхилення до середнього),
        #     d - середньоденна витрата, L - термін виконання замовлення (днів).
        # Результат обмежується знизу значенням d*L*0.5 для уникнення занадто малих запасів.
        z = 1.65                                                        # z-коефіцієнт для 95% рівня обслуговування
        sigma_l = cv * daily * math.sqrt(max(delivery, 1))              # стандартне відхилення за час L
        return max(round(z * sigma_l, 1), round(daily * delivery * 0.5, 1)) # повернути більше з двох оцінок

    def get_stocks(self, name=None):
        # Розрахунок поточного залишку по кожному товару.
        # Метод послідовно обходить всі записані операції і підсумовує:
        # +qty для приходу та -qty для витрати й списання.
        # Якщо передано ім'я товару - повертає одне число, інакше - словник усіх залишків.
        stocks = {p["name"]: 0.0 for p in self.data["products"]}        # словник залишків, всі = 0
        for m in self.data["movements"]:                                # обійти всі операції
            n = m["product"]                                            # назва товару
            if n not in stocks:                                         # якщо товар не в словнику
                stocks[n] = 0.0                                         # ініціалізувати нулем
            if m["type"] == self.TYPE_INCOME:                           # якщо прихід
                stocks[n] += m["qty"]                                   # збільшити залишок
            else:
                stocks[n] -= m["qty"]                                   # зменшити залишок
        if name is not None:                                            # якщо запитали один товар
            return round(stocks.get(name, 0.0), 2)                      # повернути залишок одного товару
        return {k: round(v, 2) for k, v in stocks.items()}              # повернути всі залишки

    def get_status(self, p, cur):
        # Визначення статусу залишку товару за чотирма рівнями:
        # empty    - товар відсутній на складі (cur <= 0)
        # critical - залишок менший за половину мінімального запасу
        # order    - залишок нижче точки замовлення (ROP = d*L + min_stock)
        # ok       - залишок достатній
        d, L = p["daily_consumption"], p["delivery_days"]               # витрата за день і термін доставки
        reorder = d * L + p["min_stock"]                                # точка замовлення
        if cur <= 0:                                                    # товару немає взагалі
            return "empty"                                              # статус: відсутній
        if cur < p["min_stock"] * 0.5:                                  # менше половини мінімуму
            return "critical"                                           # статус: критично
        if cur < p["min_stock"]:                                        # нижче мінімуму
            return "order"                                              # статус: потрібне замовлення
        if cur <= reorder:                                              # нижче точки замовлення
            return "order"                                              # статус: потрібне замовлення
        return "ok"                                                     # статус: норма

    def get_reorder_point(self, p):
        # Точка замовлення (ROP - Reorder Point) - рівень залишку,
        # при досягненні якого необхідно оформлювати замовлення постачальнику.
        # Формула: ROP = d * L + min_stock
        return round(p["daily_consumption"] * p["delivery_days"] + p["min_stock"], 1) # ROP = d*L + мін.запас

    def get_days_left(self, p, cur):
        # Прогнозована кількість днів, на які вистачить поточного залишку.
        # При нульовій витраті повертається символ "∞" (нескінченність).
        d = p["daily_consumption"]                                      # денна витрата
        return round(cur / d, 1) if d > 0 else "∞"                      # днів = залишок / витрата, або нескінченність

    def get_order_qty(self, p, cur):
        # Рекомендований обсяг замовлення для поповнення запасу до оптимального рівня.
        # Цільовий рівень = ROP + страховий запас + витрата за термін доставки.
        # Якщо поточний залишок вже перевищує ціль - повертається 0.
        reorder = self.get_reorder_point(p)                             # розрахувати точку замовлення
        target = reorder + p["safety_stock"] + p["daily_consumption"] * p["delivery_days"] # цільовий рівень запасу
        need = target - cur                                             # скільки не вистачає
        return round(max(0, need), 2)                                   # не менше нуля, округлити

    def add_movement(self, product, mov_type, qty, comment):
        # Додавання нового запису про операцію з товаром.
        # Кожен запис отримує унікальний ідентифікатор, поточну дату та час.
        # Після додавання дані автоматично зберігаються на диск.
        now = datetime.now()                                            # поточний момент
        new_id = max((m["id"] for m in self.data["movements"]), default=0) + 1 # наступний вільний ID
        mov = {
            "id": new_id,                                               # унікальний номер запису
            "date": now.strftime("%Y-%m-%d"),                           # дата у форматі рік-місяць-день
            "time": now.strftime("%H:%M:%S"),                           # час у форматі год:хв:сек
            "product": product,                                         # назва товару
            "type": mov_type,                                           # тип операції
            "qty": qty,                                                 # кількість
            "comment": comment                                          # коментар
        }
        self.data["movements"].append(mov)                              # додати операцію до списку
        self._audit("ADD_MOV", f"{mov_type} | {product} × {qty}")       # записати в журнал аудиту
        self.save()                                                     # зберегти на диск
        return mov                                                      # повернути створену операцію

    def _audit(self, action, detail):
        # Запис події до журналу аудиту.
        # Аудит фіксує всі зміни даних: додавання, редагування, видалення операцій і товарів.
        # Використовується для контролю та відстеження дій користувача.
        self.data["audit"].append({                                     # додати запис до аудиту
            "ts": datetime.now().isoformat(timespec="seconds"),         # точний час події
            "action": action,                                           # тип дії
            "detail": detail                                            # деталі дії
        })

    def get_dashboard_stats(self):
        # Формування зведеної статистики для дашборду.
        # Повертає: загальну кількість товарів, кількість за статусами,
        # обсяг приходу та витрати за поточний день,
        # дані для побудови графіка руху товарів за останні 30 днів.
        stocks = self.get_stocks()                                      # отримати всі поточні залишки
        prods = self.data["products"]                                   # список товарів
        total = len(prods)                                              # загальна кількість товарів
        statuses = {p["name"]: self.get_status(p, stocks.get(p["name"], 0)) for p in prods} # статус для кожного товару
        critical = sum(1 for s in statuses.values() if s in ("critical", "empty")) # рахувати критичних
        order    = sum(1 for s in statuses.values() if s == "order")    # рахувати що потребують замовлення
        ok       = total - critical - order                             # решта - в нормі
        today = datetime.now().strftime("%Y-%m-%d")                     # сьогоднішня дата
        today_in  = sum(m["qty"] for m in self.data["movements"] if m["date"] == today and m["type"] == self.TYPE_INCOME) # прихід сьогодні
        today_out = sum(m["qty"] for m in self.data["movements"] if m["date"] == today and m["type"] != self.TYPE_INCOME) # витрата сьогодні
        days_data = {}
        for i in range(30):                                             # останні 30 днів
            d = (datetime.now() - timedelta(days=i)).strftime("%Y-%m-%d") # дата i днів тому
            days_data[d] = {"in": 0.0, "out": 0.0}                      # нулі для кожного дня
        for m in self.data["movements"]:                                # обійти всі операції
            d = m["date"]                                               # дата операції
            if d in days_data:                                          # якщо день в межах 30 днів
                if m["type"] == self.TYPE_INCOME:                       # якщо прихід
                    days_data[d]["in"] += m["qty"]                      # додати до приходу дня
                else:
                    days_data[d]["out"] += m["qty"]                     # додати до витрати дня
        return {                                                        # вийти з методу
            "total": total, "critical": critical, "order": order, "ok": ok, # конфіг статусу: норма
            "today_in": round(today_in, 2), "today_out": round(today_out, 2),
            "total_movements": len(self.data["movements"]),
            "chart_data": dict(sorted(days_data.items()))
        }

    def import_from_excel(self, path):
        # Імпорт операцій з файлу Excel.
        if not OPENPYXL_OK:
            raise ImportError("openpyxl не встановлено. Встановіть: pip install openpyxl")

        # Метод автоматично визначає індекси потрібних колонок за ключовими словами
        # у заголовку (перший рядок файлу). Підтримує файли від різних систем
        # завдяки гнучкому пошуку назв колонок.
        ws = wb.active
        rows = list(ws.iter_rows(values_only=True))
        if not rows:
            return 0                                                    # вийти з методу
        headers = [str(h).strip().lower() if h else "" for h in rows[0]]

        def find_col(candidates):
            for c in candidates:
                for i, h in enumerate(headers):
                    if c in h:
                        return i                                        # вийти з методу
            return None                                                 # вийти з методу

        ci_prod = find_col(["товар", "product", "номенкл", "назва", "name"])
        ci_type = find_col(["тип", "type", "вид", "операц"])
        ci_qty  = find_col(["кількість", "кол", "qty", "quantity", "amount"])
        ci_comm = find_col(["комент", "comment", "примітк", "note"])
        if ci_prod is None or ci_qty is None:
            raise ValueError("Не знайдено колонки 'Товар' та 'Кількість'") # спровокувати помилку
        product_names = {p["name"].lower(): p["name"] for p in self.data["products"]}
        count = 0                                                       # лічильник відображених
        for row in rows[1:]:
            try:
                prod_raw = str(row[ci_prod]).strip() if row[ci_prod] else ""
                if not prod_raw or prod_raw.lower() == "none":
                    continue                                            # перейти до наступного
                prod = product_names.get(prod_raw.lower(), prod_raw)
                qty = float(row[ci_qty]) if row[ci_qty] is not None else 0
                if qty <= 0:                                            # перевірити що > 0
                    continue                                            # перейти до наступного
                mov_type = self.TYPE_INCOME
                if ci_type is not None and row[ci_type]:
                    t = str(row[ci_type]).strip().lower()
                    if any(x in t for x in ["расход", "витрат", "expense", "розхід", "списан", "writeoff", "write"]):
                        mov_type = self.TYPE_EXPENSE
                comment = str(row[ci_comm]).strip() if ci_comm is not None and row[ci_comm] else "Імпорт Excel"
                self.add_movement(prod, mov_type, qty, comment)
                count += 1                                              # збільшити лічильник
            except Exception:
                continue                                                # перейти до наступного
        wb.close()
        return count                                                    # вийти з методу


