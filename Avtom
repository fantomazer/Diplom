# Клас таблиці з підтримкою сортування за колонками.
# При кліку на заголовок колонки рядки сортуються за зростанням,
# повторний клік - за спаданням. Підтримує числове та алфавітне сортування.
class SortableTreeview(ttk.Treeview):
    def __init__(self, parent, **kw):
        super().__init__(parent, **kw)
        self._sc, self._sd = None, False  # поточна колонка та напрям сортування

    def enable_sorting(self):
        for col in self["columns"]:
            self.heading(col, command=lambda c=col: self._sort(c))

    def _sort(self, col):
        desc = (self._sc == col) and (not self._sd)
        rows = [(self.set(ch, col), ch) for ch in self.get_children("")]
        try:
            rows.sort(key=lambda x: float(x[0]) if x[0] not in ("∞", "") else 1e9, reverse=desc)
        except ValueError:
            rows.sort(key=lambda x: x[0].lower(), reverse=desc)
        for i, (_, ch) in enumerate(rows):
            self.move(ch, "", i)
        self._sc, self._sd = col, desc
        for c in self["columns"]:
            t = self.heading(c)["text"].replace(" ▲", "").replace(" ▼", "")
            self.heading(c, text=t)
        t = self.heading(col)["text"].replace(" ▲", "").replace(" ▼", "")
        self.heading(col, text=t + (" ▼" if desc else " ▲"))

    def bind_mousewheel(self):
        def _scroll(event):
            if event.delta:
                self.yview_scroll(int(-1 * (event.delta / 120)), "units")
            elif event.num == 4:
                self.yview_scroll(-1, "units")
            elif event.num == 5:
                self.yview_scroll(1, "units")
        self.bind("<MouseWheel>", _scroll)
        self.bind("<Button-4>", _scroll)
        self.bind("<Button-5>", _scroll)


# Головний клас програми
# Реалізує весь графічний інтерфейс і є посередником між моделлю даних (DataModel)
# та користувачем. Кожна вкладка програми будується окремим методом _build_*.
# Клас також відповідає за автооновлення даних, застосування теми та гарячі клавіші.
class InventoryApp:
    def __init__(self, root, settings):
        self.root = root                                                # головне вікно
        self.settings = settings                                        # поточні налаштування
        self.lang_code  = settings.get("lang", "uk")                    # код мови
        self.theme_name = settings.get("theme", "light")                # назва теми
        self.T = LANG[self.lang_code]                                   # словник перекладів
        global C                                                        # оголосити C глобальною
        C = THEMES[self.theme_name]                                     # завантажити активну тему

        self.root.title(f"{self.T['app_title']}  v{APP_VERSION}")       # заголовок вікна
        self.root.geometry("1440x900")                                  # розмір вікна при запуску
        self.root.minsize(1100, 700)                                    # мінімальний допустимий розмір
        self.root.configure(bg=C["bg"])                                 # колір фону вікна
        self.model = DataModel()                                        # створити модель даних

        # Прапорець і лічильник для механізму автооновлення кожні 5 секунд.
        # Оновлення відбувається лише якщо змінилась кількість операцій у моделі.
        self._auto_refresh    = True                                    # автооновлення увімкнено
        self._auto_refresh_id = None                                    # ID таймера оновлення
        self._last_mov_count  = len(self.model.data["movements"])       # кількість операцій при останньому оновленні

        self._setup_styles()                                            # налаштувати стилі ttk
        self._build_ui()                                                # побудувати інтерфейс
        self._bind_hotkeys()                                            # прив'язати гарячі клавіші
        self.root.after(800,  self._check_critical_on_startup)          # перевірити критичні залишки через 0.8с
        self.root.after(5000, self._auto_refresh_tick)                  # перший тік автооновлення через 5с
        self.root.protocol("WM_DELETE_WINDOW", self._on_close)          # обробник закриття вікна

    def T_(self, key, *args):
        # Отримання локалізованого рядка за ключем. При наявності аргументів
        # підставляє їх через str.format(). Якщо ключ не знайдено - повертає сам ключ.
        s = self.T.get(key, key)
        if args:
            try:
                return s.format(*args)                                  # вийти з методу
            except Exception:
                return s                                                # вийти з методу
        return s                                                        # вийти з методу

    def _type_label(self, internal_type):
        # Перетворення внутрішнього коду типу операції на локалізований рядок для відображення.
        map_ = {                                                        # словник: внутр.код -> відображуваний рядок
            DataModel.TYPE_INCOME:   self.T_("lbl_income"),
            DataModel.TYPE_EXPENSE:  self.T_("lbl_expense"),
            DataModel.TYPE_WRITEOFF: self.T_("lbl_writeoff"),
        }
        return map_.get(internal_type, internal_type)                   # повернути мітку або сам код якщо не знайдено

    def _type_from_label(self, label):
        # Зворотне перетворення: з відображуваного рядка у внутрішній код типу.
        # Перевіряє підрядки для стійкості до відмінностей у регістрі та мові.
        label_lower    = label.strip().lower()                          # привести до нижнього регістру
        income_labels  = [self.T_("lbl_income").lower(),  "income",  "приход", "прихід"] # можливі позначення приходу
        expense_labels = [self.T_("lbl_expense").lower(), "expense", "расход", "витрата"] # можливі позначення витрати
        if any(l in label_lower for l in income_labels):                # якщо це прихід
            return DataModel.TYPE_INCOME                                # повернути код приходу
        if any(l in label_lower for l in expense_labels):               # якщо це витрата
            return DataModel.TYPE_EXPENSE                               # повернути код витрати
        return DataModel.TYPE_WRITEOFF                                  # якщо не прихід і не витрата - списання

    # Налаштування стилів ttk
    # Метод задає єдину колірну схему для всіх стандартних компонентів tkinter/ttk:
    # фреймів, кнопок, таблиць, вкладок, полів вводу тощо.
    # Викликається при ініціалізації та при зміні теми оформлення.
    def _setup_styles(self):
        st = ttk.Style()
        st.theme_use("clam")
        st.configure(".", background=C["bg"], foreground=C["text"],
                      fieldbackground=C["input_bg"], font=FNT)
