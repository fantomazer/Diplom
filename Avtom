        self._st_tree.pack(fill="both", expand=True)
        STATUS_CFG = self._get_status_cfg()                             # конфіги статусів
        for s, cfg in STATUS_CFG.items():
            self._st_tree.tag_configure(s, foreground=cfg["color"])
        self._st_tree.tag_configure("alt", background=C["row_alt"])

        ctx = tk.Menu(self.root, tearoff=0, bg=C["bg"], fg=C["text"],
                       activebackground=C["sel"], font=FNT)
        ctx.add_command(label=self.T_("edit_stock"), command=self._edit_stock_dialog)
        ctx.add_command(label=self.T_("history"),    command=self._show_prod_movements)
        self._st_tree.bind("<Button-3>", lambda e: ctx.post(e.x_root, e.y_root))
        self._st_tree.bind("<Double-1>", lambda _: self._edit_stock_dialog())

        # Заповнюємо тулбар (створений вище, до таблиці)
        ttk.Button(self._st_btn_frame, text=self.T_("edit_stock"), command=self._edit_stock_dialog,
                    style="Accent.TButton").pack(side="left", padx=2)
        ttk.Button(self._st_btn_frame, text=self.T_("history"),    command=self._show_prod_movements).pack(side="left", padx=2)
        ttk.Button(self._st_btn_frame, text=self.T_("btn_refresh"),command=self._refresh_stock_tab).pack(side="left",  padx=2)
        ttk.Button(self._st_btn_right, text=self.T_("btn_excel"),  command=self._export_stock_excel).pack(side="right", padx=2)
        self._refresh_stock_tab()                                       # перезавантажити залишки

    def _refresh_stock_tab(self):
        self._st_tree.delete(*self._st_tree.get_children())             # очистити таблицю залишків
        stocks = self.model.get_stocks()                                # отримати залишки
        STATUS_CFG = self._get_status_cfg()                             # конфіги статусів
        for idx, p in enumerate(self.model.data["products"]):           # перебрати товари
            cur    = stocks.get(p["name"], 0.0)                  # поточний залишок
            status = self.model.get_status(p, cur)                      # статус
            rp     = self.model.get_reorder_point(p)                    # точка замовлення
            dl     = self.model.get_days_left(p, cur)                   # днів залишилось
            need   = self.model.get_order_qty(p, cur)                   # скільки замовити
            cfg    = STATUS_CFG[status]                                 # конфіг статусу
            tags   = (status, "alt") if idx % 2 == 0 else (status,)     # теги кольору
            unit   = p.get("unit", self.T_("pcs"))                      # одиниця виміру
            self._st_tree.insert("", "end", values=(
                p["name"], unit, p.get("category", ""),
                f"{cur} {unit}", p["min_stock"],
                p["safety_stock"], rp, dl,
                f"{need:.1f}" if need > 0 else "-",                     # показати кількість або прочерк
                f"{cfg['icon']} {cfg['label']}"
            ), tags=tags)                                               # застосувати теги кольору
        self._load_products()                                           # оновити довідник

    def _edit_stock_dialog(self):
        sel = self._st_tree.selection()
        if not sel:                                                     # якщо нічого не виділено
            messagebox.showwarning(self.T_("warning_title"), self.T_("warn_sel_p")) # показати попередження
            return                                                      # вийти з методу
        name = self._st_tree.item(sel[0])["values"][0]
        p = next((x for x in self.model.data["products"] if x["name"] == name), None)
        if not p:
            return                                                      # вийти з методу
        cur = self.model.get_stocks(name)
        dlg = tk.Toplevel(self.root)
        dlg.title(f"{self.T_('edit_stock')}: {name}")
        dlg.geometry("420x250")
        dlg.configure(bg=C["bg"])
        dlg.transient(self.root)
        dlg.grab_set()
        dlg.resizable(False, False)

        tk.Label(dlg, text=f"📦 {name}", bg=C["bg"], fg=C["text"], font=FNTB).pack(pady=(16, 8))
        frm = tk.Frame(dlg, bg=C["bg"])
        frm.pack(padx=24, fill="x")

        ttk.Label(frm, text=self.T_("current_stock")).grid(row=0, column=0, sticky="e", padx=(0, 10), pady=8)
        ttk.Label(frm, text=f"{cur} {p.get('unit', self.T_('pcs'))}",
                   font=FNTB).grid(row=0, column=1, sticky="w", pady=8)

        ttk.Label(frm, text=self.T_("new_stock")).grid(row=1, column=0, sticky="e", padx=(0, 10), pady=8)
        nsv = tk.StringVar(value=str(cur))
        nse = ttk.Entry(frm, textvariable=nsv, width=20)
        nse.grid(row=1, column=1, sticky="w", pady=8)

        ttk.Label(frm, text=self.T_("lbl_comment")).grid(row=2, column=0, sticky="e", padx=(0, 10), pady=8)
        ce = ttk.Entry(frm, width=28)
        ce.insert(0, self.T_("manual_adj"))
        ce.grid(row=2, column=1, sticky="w", pady=8)

        def save():
            try:
                ns = float(nsv.get())
                if ns < 0:
                    raise ValueError                                    # спровокувати помилку
            except ValueError:
                messagebox.showerror(self.T_("error_title"), self.T_("err_stock")) # показати помилку
                return                                                  # вийти з методу
            diff = ns - cur
            if abs(diff) < 0.001:
                dlg.destroy()                                           # закрити діалог
                return                                                  # вийти з методу
            mov_type = DataModel.TYPE_INCOME if diff > 0 else DataModel.TYPE_EXPENSE
            self.model.add_movement(name, mov_type, abs(diff),
                                    ce.get().strip() or self.T_("manual_adj"))
            self.model._audit("STOCK_ADJUST", f"{name}: {cur} → {ns}")
            self._last_mov_count = len(self.model.data["movements"])    # оновити лічильник
            self._refresh_stock_tab()                                   # перезавантажити залишки
            self._load_movements()                                      # перезавантажити таблицю рухів
            self.refresh_dashboard()                                    # оновити дашборд
            self._status(self.T_("stock_changed", name, cur, ns), C["success"])
            dlg.destroy()                                               # закрити діалог

        br = tk.Frame(dlg, bg=C["bg"])
        br.pack(pady=16)
        ttk.Button(br, text=self.T_("btn_save"),   style="Accent.TButton", command=save).pack(side="left", padx=6)
        ttk.Button(br, text=self.T_("btn_cancel"), command=dlg.destroy).pack(side="left", padx=6)
        nse.focus()
        nse.select_range(0, "end")

    def _show_prod_movements(self):
        sel = self._st_tree.selection()
        if not sel:                                                     # якщо нічого не виділено
            return                                                      # вийти з методу
        name = self._st_tree.item(sel[0])["values"][0]
        self.nb.select(1)
        self._f_prod.set(name)
        self._f_typ.set(self.T_("lbl_all"))
        self._apply_filters()

    # Вкладка "Розрахунок запасів"
    # Детальний розрахунок страхового запасу, точки замовлення та EOQ
    # для обраного товару з візуальним індикатором рівня запасу.
    def _build_calculator(self, parent):
        sf = tk.Frame(parent, bg=C["bg"])
        sf.pack(fill="x", padx=14, pady=(12, 6))
        ttk.Label(sf, text=self.T_("lbl_product")).pack(side="left", padx=(0, 6))
        self._calc_prod = ttk.Combobox(sf, width=36)
        self._calc_prod.pack(side="left", padx=(0, 12))
        self._calc_prod.bind("<<ComboboxSelected>>", lambda _: self._calculate())
        ttk.Label(sf, text=self.T_("calc_cv")).pack(side="left", padx=(14, 6))
        self._calc_cv = ttk.Entry(sf, width=6)
        self._calc_cv.insert(0, "0.3")
        self._calc_cv.pack(side="left", padx=(0, 12))
        Tooltip(self._calc_cv, "Коефіцієнт варіації попиту (0.1–0.5)")
        ttk.Button(sf, text=self.T_("calc_btn"), style="Accent.TButton",
                    command=self._calculate).pack(side="left", padx=4)

        ro = tk.Frame(parent, bg=C["bg"])
        ro.pack(fill="both", expand=True, padx=14, pady=6)
        ro.columnconfigure(0, weight=1)
        ro.columnconfigure(1, weight=1)

        left = ttk.LabelFrame(ro, text=f"  🧮 {self.T_('detail_calc')}", padding=10)
        left.grid(row=0, column=0, sticky="nsew", padx=(0, 6))
        self._calc_txt = tk.Text(left, wrap="word", bg=C["canvas_bg"], fg=C["text"],
                                  insertbackground=C["text"], font=FNTM,
                                  borderwidth=0, padx=10, pady=8)
        sc = ttk.Scrollbar(left, orient="vertical", command=self._calc_txt.yview)
        sc.pack(side="right", fill="y")
        self._calc_txt.configure(yscrollcommand=sc.set)
        self._calc_txt.pack(fill="both", expand=True)
        for tag, fc in [("h", C["accent"]), ("v", C["success"]), ("f", C["text3"]),
                         ("w", C["warning"]), ("e", C["danger"])]:
            self._calc_txt.tag_configure(tag, foreground=fc)
        self._calc_txt.tag_configure("b", font=(FNTM[0], FNTM[1], "bold"))

        right = ttk.LabelFrame(ro, text=f"  📊 {self.T_('calc_results')}", padding=10)
        right.grid(row=0, column=1, sticky="nsew", padx=(6, 0))
        self._calc_kpi_fr = tk.Frame(right, bg=C["bg"])
        self._calc_kpi_fr.pack(fill="x")
        self._gauge_cv = tk.Canvas(right, bg=C["canvas_bg"], height=160,
                                    highlightthickness=1, highlightbackground=C["border"])
        self._gauge_cv.pack(fill="x", pady=(14, 0))
        self._update_calc_prod_list()

    def _update_calc_prod_list(self):
        names = [p["name"] for p in self.model.data["products"]]        # список назв товарів
        self._calc_prod["values"] = names                               # оновити список в калькуляторі
        if names and not self._calc_prod.get():
            self._calc_prod.set(names[0])

    def _calculate(self):
        name = self._calc_prod.get()
        if not name:                                                    # якщо порожнє - помилка
            return                                                      # вийти з методу
        p = next((x for x in self.model.data["products"] if x["name"] == name), None)
        if not p:
            return                                                      # вийти з методу
        try:
            cv = float(self._calc_cv.get())
        except ValueError:
            cv = 0.3
        cv = max(0.05, min(cv, 1.0))                                    # обмежити CV в межах 0.05-1.0
        daily    = p["daily_consumption"]                               # денна витрата товару
        delivery = p["delivery_days"]                                   # термін доставки
        min_st   = p["min_stock"]                                       # мінімальний запас
        monthly  = p["monthly_consumption"]                             # місячна витрата
        current  = self.model.get_stocks(name)                          # поточний залишок
        unit     = p.get("unit", self.T_("pcs"))                        # одиниця виміру

        z = 1.65                                                        # z-коефіцієнт для 95% рівня обслуговування
        sigma_l = cv * daily * math.sqrt(max(delivery, 1))              # стандартне відхилення за час L
        safety  = max(round(z * sigma_l, 1), round(daily * delivery * 0.5, 1)) # страховий запас
        max_st  = daily * delivery + safety                             # максимальний запас
        reorder = daily * delivery + min_st                             # точка замовлення
        days_left = round(current / daily, 1) if daily > 0 else float("inf") # днів запасу
        need = max(0, reorder + safety - current)                       # потреба в замовленні
        eoq = round(math.sqrt(2 * monthly * delivery / max(daily, 0.01)), 1) if daily > 0 else 0 # оптимальна партія EOQ

        txt = self._calc_txt
        txt.config(state="normal")                                      # дозволити редагування тексту
        txt.delete("1.0", "end")                                        # очистити текстове поле

        def w(text, tag=None):
            txt.insert("end", text, tag or "")

        w("═" * 56 + "\n", "h")
        w(f"  РОЗРАХУНОК ЗАПАСІВ\n", ("h", "b"))
        w(f"  {p['name']}\n", ("h", "b"))
        w("═" * 56 + "\n\n", "h")

        w("  ВХІДНІ ПАРАМЕТРИ\n", ("h", "b"))
        w("  ─" * 28 + "\n", "f")
        params = [
            (self.T_("daily_cons"),    f"{daily} {unit}/день"),
            (self.T_("monthly_cons"),  f"{monthly} {unit}/міс"),
            (self.T_("min_stock"),     f"{min_st} {unit}"),
            (self.T_("delivery_days"), f"{delivery} днів"),
            (self.T_("calc_cv"),       f"{cv:.2f}  (σ/μ попиту)"),
            (self.T_("col_current"),   f"{round(current, 2)} {unit}"),
        ]
        for lbl, val in params:
            w(f"  {lbl:<28}", None)
            w(f"{val}\n", "v")

        w("\n  РЕЗУЛЬТАТИ РОЗРАХУНКУ\n", ("h", "b"))
        w("  ─" * 28 + "\n", "f")

        w("\n  1. Страховий запас (Safety Stock)\n", "h")
        w(f"     Формула: Z(95%) × CV × d × √L\n", "f")
        w(f"     = {z} × {cv} × {daily} × √{delivery}\n", "f")
        w(f"     = ", None)
        w(f"{safety} {unit}\n\n", ("v", "b"))

        w("  2. Точка замовлення (ROP)\n", "h")
        w(f"     Формула: d × L + мін.запас\n", "f")
        w(f"     = {daily} × {delivery} + {min_st}\n", "f")
        w(f"     = ", None)
        w(f"{reorder:.1f} {unit}\n\n", ("v", "b"))

        w("  3. Максимальний запас\n", "h")
        w(f"     = d × L + страховий = ")
        w(f"{max_st:.1f} {unit}\n\n", ("v", "b"))

        w("  4. Оптимальне замовлення (EOQ)\n", "h")
        w(f"     = √(2 × місячна витрата × L / d)\n", "f")
        w(f"     = ", None)
        w(f"{eoq} {unit}\n\n", ("v", "b"))

        w("  5. Прогноз поточного запасу\n", "h")
        if daily > 0:
            w(f"     Поточний запас: ")
            w(f"{round(current, 2)} {unit}\n", "v")
            w(f"     Вистачить на: ")
            w(f"{days_left} {self.T_('days')}\n", "v" if isinstance(days_left, float) and days_left > delivery else "w")
            if isinstance(days_left, float):
                fd = datetime.now() + timedelta(days=float(days_left))
                w(f"     Прогноз вичерпання: ")
                w(f"{fd.strftime('%d.%m.%Y')}\n", "w")

        w("\n  ─" * 28 + "\n", "f")
        if need > 0:
            w(f"\n  ➡ РЕКОМЕНДУЄТЬСЯ ЗАМОВИТИ:\n", ("w", "b"))
            w(f"     {round(need, 1)} {unit}\n\n", ("e", "b"))
        else:
            w(f"\n  ✅ Запас достатній, замовлення не потрібне\n", ("v", "b"))
        w("═" * 56 + "\n", "h")
        txt.config(state="disabled")                                    # заборонити редагування

        # KPI картки
        for wg in self._calc_kpi_fr.winfo_children():                   # перебрати старі картки
            wg.destroy()                                                # видалити стару картку
        kpi_data = [
            ("Страховий запас",    f"{safety} {unit}",           C["accent"]),
            ("Точка замовлення",   f"{reorder:.1f} {unit}",      C["warning"]),
            ("Макс. запас",        f"{max_st:.0f} {unit}",       C["text2"]),
            ("Оптим. замовл (EOQ)",f"{eoq} {unit}",              C["accent"]),
            ("Поточний залишок",   f"{round(current, 2)} {unit}",C["success"] if need == 0 else C["danger"]),
            ("Залишилось днів",    str(days_left) if daily > 0 else "∞",
             C["success"] if isinstance(days_left, float) and days_left > delivery * 2 else C["warning"]),
            ("Треба замовити",     f"{round(need, 1)} {unit}" if need > 0 else "Не потрібно",
             C["danger"] if need > 0 else C["success"]),
        ]
        for lbl, val, color in kpi_data:
            row = tk.Frame(self._calc_kpi_fr, bg=C["canvas_bg"], pady=6, padx=12,
                           highlightthickness=1, highlightbackground=C["border"])
            row.pack(fill="x", pady=2)
            tk.Label(row, text=lbl, bg=C["canvas_bg"], fg=C["text3"],
                     font=FNTS, width=22, anchor="w").pack(side="left")
            tk.Label(row, text=val, bg=C["canvas_bg"], fg=color, font=FNTB).pack(side="right")
        self._draw_gauge(current, reorder, max_st)

    def _draw_gauge(self, current, reorder, max_st):
        cv = self._gauge_cv
        cv.delete("all")
        w = cv.winfo_width()
        h = cv.winfo_height() or 160
        if w < 50:
            self.root.after(150, lambda: self._draw_gauge(current, reorder, max_st))
            return                                                      # вийти з методу
        cx, cy, r = w // 2, h - 20, min(w // 2 - 20, h - 40) - 8        # центр і радіус манометра
        if r < 20:
            return                                                      # вийти з методу
        total = max_st if max_st > 0 else 1                             # максимальне значення шкали
        pct = min(current / total, 1.0)                                 # частка поточного від максимуму
        rp  = min(reorder / total, 1.0)                                 # частка точки замовлення
        fill_color = (C["success"] if pct > rp else                     # зелений якщо вище ROP
                      C["danger"] if pct < rp * 0.4 else C["warning"])
        # Фон дуги
        for i in range(180):                                            # малюємо 180 градусів дуги
            a1 = math.radians(180 - i)                                  # кут в радіанах
            cv.create_arc(cx - r, cy - r, cx + r, cy + r,
                          start=math.degrees(a1), extent=-1,
                          style="arc", outline=C["border"], width=14)
        # Заповнення
        fill_steps = int(pct * 180)                                     # скільки градусів заповнити
        for i in range(fill_steps):
            a1 = math.radians(180 - i)                                  # кут в радіанах
            cv.create_arc(cx - r, cy - r, cx + r, cy + r,
                          start=math.degrees(a1), extent=-1,
                          style="arc", outline=fill_color, width=14)
        # Мітка ROP
        rp_angle = math.radians(180 - rp * 180)                         # кут мітки точки замовлення
        mx = cx + r * math.cos(rp_angle)                                # x мітки ROP
        my = cy - r * math.sin(rp_angle)                                # y мітки ROP
        cv.create_oval(mx - 7, my - 7, mx + 7, my + 7,
                        fill=C["warning"], outline="white", width=2)
        # Стрілка
        angle = math.radians(180 - pct * 180)                           # кут стрілки
        ax = cx + (r - 22) * math.cos(angle)                            # кінець стрілки x
        ay = cy - (r - 22) * math.sin(angle)                            # кінець стрілки y
        cv.create_line(cx, cy, ax, ay, fill=C["text"], width=3, arrow="last")
        cv.create_oval(cx - 6, cy - 6, cx + 6, cy + 6, fill=C["text"], outline="")
        # Мітки
        cv.create_text(cx - r - 4, cy + 6, text="0", fill=C["text3"], font=("Segoe UI", 8), anchor="e")
        cv.create_text(cx + r + 4, cy + 6, text=f"{max_st:.0f}", fill=C["text3"], font=("Segoe UI", 8), anchor="w")
        cv.create_text(cx, cy - r - 10, text=f"{current:.1f} {''}", fill=fill_color,
                        font=("Segoe UI", 13, "bold"))
        cv.create_text(cx, cy + 12, text="Рівень запасу", fill=C["text3"], font=("Segoe UI", 9))

