    def _refresh_stats(self):
        self._draw_top5_chart()
        self._draw_cat_chart()
        self._draw_inc_exp_chart()
        self._draw_turnover_chart()

    def _draw_top5_chart(self):
        cv = self._top5_cv; cv.delete("all")
        w = cv.winfo_width(); h = cv.winfo_height()
        if w < 10: return                                               # вийти з методу
        cutoff = (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d")
        totals = {}
        for m in self.model.data["movements"]:
            if m["type"] != DataModel.TYPE_INCOME and m["date"] >= cutoff:
                totals[m["product"]] = totals.get(m["product"], 0) + m["qty"]
        if not totals:
            cv.create_text(w//2, h//2, text="Немає даних за 30 днів",
                            fill=C["text3"], font=FNT); return          # вийти з методу
        items = sorted(totals.items(), key=lambda x: x[1], reverse=True)[:5]
        max_v = max(v for _, v in items) or 1
        colors = [C["accent"],C["success"],C["warning"],C["danger"],"#8B5CF6"]
        pl = 170; pr = 70; gap = 10
        bar_h = min(30, (h - 30) // (len(items) + 1))
        total_h = len(items) * (bar_h + gap)
        y_start = (h - total_h) // 2
        for i, (name, val) in enumerate(items):
            y = y_start + i * (bar_h + gap)
            bar_w = int((val / max_v) * (w - pl - pr - 20))
            color = colors[i % len(colors)]
            lbl = name[:20] + "…" if len(name) > 20 else name
            cv.create_text(pl - 10, y + bar_h//2, text=lbl, anchor="e",
                            fill=C["text2"], font=FNTS)
            cv.create_rectangle(pl, y, pl + w - pl - pr - 20, y + bar_h,
                                  fill=C["border"], outline="")
            if bar_w > 0:
                cv.create_rectangle(pl, y, pl + bar_w, y + bar_h, fill=color, outline="")
            cv.create_text(pl + bar_w + 8, y + bar_h//2, text=f"{val:.1f}",
                            anchor="w", fill=color, font=("Segoe UI", 9, "bold"))

    def _draw_cat_chart(self):
        cv = self._cat_cv; cv.delete("all")
        w = cv.winfo_width(); h = cv.winfo_height()
        if w < 10: return                                               # вийти з методу
        stocks = self.model.get_stocks()                                # отримати залишки
        cat_totals = {}
        for p in self.model.data["products"]:                           # перебрати всі товари
            cat = p.get("category", "-") or "-"
            cat_totals[cat] = cat_totals.get(cat, 0) + max(0, stocks.get(p["name"], 0))
        if not cat_totals or sum(cat_totals.values()) == 0:
            cv.create_text(w//2, h//2, text="Немає даних",
                            fill=C["text3"], font=FNT); return          # вийти з методу
        total = sum(cat_totals.values())
        cx, cy = w // 2 - 40, h // 2
        r = min(cx - 10, cy - 10) - 10
        if r < 20: return                                               # вийти з методу
        colors = [C["accent"],C["success"],C["warning"],C["danger"],"#8B5CF6","#06B6D4","#F59E0B"]
        start_angle = 90
        items = sorted(cat_totals.items(), key=lambda x: x[1], reverse=True)
        legend_y = 10
        for i, (cat, val) in enumerate(items):
            pct = val / total; extent = pct * 360; color = colors[i % len(colors)]
            cv.create_arc(cx-r, cy-r, cx+r, cy+r, start=start_angle, extent=-extent,
                          fill=color, outline=C["bg"], width=2, style="pieslice")
            if extent > 18:
                mid_angle = math.radians(start_angle - extent / 2)
                lx = cx + (r * 0.62) * math.cos(mid_angle)
                ly = cy - (r * 0.62) * math.sin(mid_angle)
                cv.create_text(lx, ly, text=f"{pct*100:.0f}%", fill="white",
                                font=("Segoe UI", 8, "bold"))
            start_angle -= extent
            lbl = cat[:14] + "…" if len(cat) > 14 else cat
            cv.create_rectangle(w-130, legend_y, w-116, legend_y+12, fill=color, outline="")
            cv.create_text(w-112, legend_y+6, text=lbl, anchor="w",
                            fill=C["text3"], font=FNTS)
            legend_y += 18

    def _draw_inc_exp_chart(self):
        cv = self._inc_exp_cv; cv.delete("all")
        w = cv.winfo_width(); h = cv.winfo_height()
        if w < 10: return                                               # вийти з методу
        # Дані по тижнях
        show_dates = {}
        for i in range(29, -1, -1):
            d = (datetime.now() - timedelta(days=i))
            lbl = d.strftime("%d.%m")
            show_dates[lbl] = {"in": 0, "out": 0}
        for m in self.model.data["movements"]:
            try:
                d_dt = datetime.strptime(m["date"], "%Y-%m-%d")
                if (datetime.now() - d_dt).days <= 30:
                    lbl = d_dt.strftime("%d.%m")
                    if lbl in show_dates:
                        if m["type"] == DataModel.TYPE_INCOME: show_dates[lbl]["in"]  += m["qty"] # прихід
                        else:                                   show_dates[lbl]["out"] += m["qty"]
            except: pass
        keys = list(show_dates.keys())
        # Показуємо кожен 3-й день
        show_keys = [keys[i] for i in range(0, len(keys), 3)]
        n = len(show_keys)
        if n == 0: return                                               # вийти з методу
        pl, pr, pt, pb = 55, 20, 20, 34; cw = w - pl - pr; ch = h - pt - pb
        max_v = max((max(show_dates[k]["in"], show_dates[k]["out"]) for k in show_keys), default=0.1)
        if max_v == 0: max_v = 1
        bw = max(5, cw // (n * 3))
        for g in range(5):
            y = pt + g * ch / 4
            cv.create_line(pl, y, w-pr, y, fill=C["border"], dash=(3,3))
            cv.create_text(pl-4, y, text=f"{max_v*(1-g/4):.0f}", anchor="e",
                            fill=C["text3"], font=("Segoe UI",7))
        for i, k in enumerate(show_keys):
            x = pl + i * cw // (n - 1 if n > 1 else 1)
            in_h  = int((show_dates[k]["in"]  / max_v) * ch)
            out_h = int((show_dates[k]["out"] / max_v) * ch)
            if in_h > 0:
                cv.create_rectangle(x - bw - 2, pt + ch - in_h, x - 2, pt + ch,
                                     fill=C["success"], outline="")
            if out_h > 0:
                cv.create_rectangle(x + 2, pt + ch - out_h, x + bw + 2, pt + ch,
                                     fill=C["danger"], outline="")
            cv.create_text(x, h - 6, text=k, fill=C["text3"], font=("Segoe UI",7))
        lx = w - 160
        cv.create_rectangle(lx,8,lx+14,18,fill=C["success"],outline="")
        cv.create_text(lx+18,13,text=self.T_("lbl_income"),anchor="w",fill=C["text3"],font=FNTS)
        cv.create_rectangle(lx,24,lx+14,34,fill=C["danger"],outline="")
        cv.create_text(lx+18,29,text=self.T_("lbl_expense"),anchor="w",fill=C["text3"],font=FNTS)

    def _draw_turnover_chart(self):
        cv = self._turn_cv; cv.delete("all")
        w = cv.winfo_width(); h = cv.winfo_height()
        if w < 10: return                                               # вийти з методу
        stocks = self.model.get_stocks()                                # отримати залишки
        turnovers = []
        for p in self.model.data["products"]:                           # перебрати всі товари
            cur = stocks.get(p["name"], 0)
            d   = p["daily_consumption"]
            t   = round(cur / d, 1) if d > 0 else 0
            turnovers.append((p["name"], t))
        turnovers.sort(key=lambda x: x[1], reverse=True)
        if not turnovers: return                                        # вийти з методу
        n = len(turnovers); max_t = max(v for _, v in turnovers) or 1
        pl = 170; pr = 70; gap = 6
        bar_h = min(24, (h - 20) // (n + 1))
        colors_fn = lambda t: C["success"] if t > 30 else (C["warning"] if t > 14 else C["danger"])
        y_start = 10
        for i, (name, t) in enumerate(turnovers):
            y = y_start + i * (bar_h + gap)
            if y + bar_h > h - 10: break
            bar_w = int((t / max_t) * (w - pl - pr - 20))
            color = colors_fn(t)
            lbl = name[:20] + "…" if len(name) > 20 else name
            cv.create_text(pl - 10, y + bar_h//2, text=lbl, anchor="e",
                            fill=C["text2"], font=("Segoe UI",8))
            cv.create_rectangle(pl, y, pl + w - pl - pr - 20, y + bar_h,
                                  fill=C["border"], outline="")
            if bar_w > 0:
                cv.create_rectangle(pl, y, pl + bar_w, y + bar_h, fill=color, outline="")
            cv.create_text(pl + bar_w + 8, y + bar_h//2, text=f"{t} {self.T_('days')}",
                            anchor="w", fill=color, font=("Segoe UI",8,"bold"))

    # Вкладка "Аудит"
    # Журнал усіх змін у системі: додавання, редагування, видалення,
    # коригування залишків, імпорт. Підтримує пошук і фільтрацію.
    def _build_audit(self, parent):
        tk.Label(parent, text=self.T_("audit_title"),
                  bg=C["bg"], fg=C["text3"], font=FNTS).pack(anchor="w", padx=12, pady=(8, 4))
        # Пошук по аудиту
        sr = tk.Frame(parent, bg=C["bg"]); sr.pack(fill="x", padx=10, pady=(0,4))
        ttk.Label(sr, text=self.T_("lbl_search")).pack(side="left", padx=(0,4))
        self._aud_search_var = tk.StringVar()
        self._aud_search_var.trace_add("write", lambda *_: self._load_audit()) # оновити аудит
        ttk.Entry(sr, textvariable=self._aud_search_var, width=30).pack(side="left")

        tf = tk.Frame(parent, bg=C["bg"]); tf.pack(fill="both", expand=True, padx=10, pady=4)
        cols = ("ts","action","detail")
        self._aud_tree = ttk.Treeview(tf, columns=cols, show="headings")
        self._aud_tree.heading("ts",     text=self.T_("col_ts"))
        self._aud_tree.heading("action", text=self.T_("col_action"))
        self._aud_tree.heading("detail", text=self.T_("col_detail"))
        self._aud_tree.column("ts",     width=160, anchor="center")
        self._aud_tree.column("action", width=150, anchor="center")
        self._aud_tree.column("detail", width=600, anchor="w", stretch=True)
        vsb = ttk.Scrollbar(tf, orient="vertical", command=self._aud_tree.yview)
        vsb.pack(side="right", fill="y")
        self._aud_tree.configure(yscrollcommand=vsb.set)
        self._aud_tree.pack(fill="both", expand=True)
        def _scroll(event):
            if event.delta: self._aud_tree.yview_scroll(int(-1*(event.delta/120)),"units")
            elif event.num==4: self._aud_tree.yview_scroll(-1,"units")
            elif event.num==5: self._aud_tree.yview_scroll(1,"units")
        self._aud_tree.bind("<MouseWheel>", _scroll)
        self._aud_tree.tag_configure("add",    foreground=C["success"])
        self._aud_tree.tag_configure("delete", foreground=C["danger"])
        self._aud_tree.tag_configure("edit",   foreground=C["warning"])

        br = tk.Frame(parent, bg=C["bg"]); br.pack(fill="x", padx=10, pady=4)
        ttk.Button(br,text=self.T_("btn_refresh"),command=self._load_audit).pack(side="left",padx=2)
        ttk.Button(br,text=self.T_("clear_log"),command=self._clear_audit,style="Danger.TButton").pack(side="left",padx=2)
        self._aud_count_lbl = ttk.Label(br, text="", font=FNTS, foreground=C["text3"])
        self._aud_count_lbl.pack(side="left", padx=12)
        self._load_audit()                                              # оновити аудит

    def _load_audit(self):
        self._aud_tree.delete(*self._aud_tree.get_children())           # очистити журнал
        search = self._aud_search_var.get().strip().lower() if hasattr(self, "_aud_search_var") else "" # пошук по аудиту
        count = 0                                                       # лічильник відображених
        for e in reversed(self.model.data.get("audit", [])):            # від нових до старих
            if search and search not in (e["action"]+e["detail"]).lower(): # фільтр пошуку
                continue                                                # перейти до наступного
            action = e["action"]                                        # тип дії
            tag = "add" if "ADD" in action else ("delete" if "DELETE" in action else "edit") # тег кольору рядка
            self._aud_tree.insert("", "end", values=(e["ts"], e["action"], e["detail"]), tags=(tag,)) # додати рядок
            count += 1                                                  # збільшити лічильник
        if hasattr(self, "_aud_count_lbl"):
            self._aud_count_lbl.config(text=f"{self.T_('records')} {count}")

    def _clear_audit(self):
        if messagebox.askyesno(self.T_("confirm_title"), self.T_("confirm_audit_clear")):
            self.model.data["audit"] = []
            self.model.save()                                           # зберегти дані перед виходом
            self._load_audit()                                          # оновити аудит

    # Вкладка "Налаштування"
    # Вибір мови інтерфейсу та теми оформлення.
    # Тема застосовується одразу без перезапуску.
    # Мова набуває чинності після перезапуску програми.
    def _build_settings(self, parent):
        canvas = tk.Canvas(parent, bg=C["bg"], highlightthickness=0)
        canvas.pack(fill="both", expand=True)
        inner = tk.Frame(canvas, bg=C["bg"])
