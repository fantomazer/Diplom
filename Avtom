# Клас підказки (tooltip), що відображається при наведенні курсору на елемент.
# Показує невелике темне вікно з текстом підказки під відповідним віджетом.
class Tooltip:
    def __init__(self, widget, text):
        self.widget = widget
        self.text = text
        self.tip = None
        widget.bind("<Enter>", self._show)
        widget.bind("<Leave>", self._hide)

    def _show(self, _=None):
        x = self.widget.winfo_rootx() + 20
        y = self.widget.winfo_rooty() + self.widget.winfo_height() + 4
        self.tip = tk.Toplevel(self.widget)
        self.tip.wm_overrideredirect(True)
        self.tip.wm_geometry(f"+{x}+{y}")
        tk.Label(
            self.tip, text=self.text,
            background="#1E293B", foreground="#F1F5F9",
            relief="flat", borderwidth=0, font=("Segoe UI", 9),
            padx=10, pady=5
        ).pack()

    def _hide(self, _=None):
        if self.tip:
            self.tip.destroy()
            self.tip = None


# Клас картки ключового показника (KPI) для дашборду.
