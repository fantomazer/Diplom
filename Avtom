    # Методи експорту даних у формат Microsoft Excel
    # Використовують бібліотеку openpyxl для формування xlsx-файлів
    # зі стилізованими заголовками, чергуванням рядків та автофільтром.
    def _std_border(self):
        t = Side(style="thin", color="CBD5E1")
        return Border(left=t, right=t, top=t, bottom=t)                 # вийти з методу

    def _excel_header(self, ws, row, headers, widths):
        hf   = Font(name="Arial", bold=True, color="FFFFFF", size=10)
        hfil = PatternFill("solid", start_color="3B82F6")
        al   = Alignment(horizontal="center", vertical="center", wrap_text=True)
        bd   = self._std_border()
        for ci, (hdr, width) in enumerate(zip(headers, widths), 1):
            c = ws.cell(row=row, column=ci, value=hdr)
            c.font = hf; c.fill = hfil; c.alignment = al; c.border = bd
            ws.column_dimensions[get_column_letter(ci)].width = width
        ws.row_dimensions[row].height = 22

    def _excel_row(self, ws, row, values, alt=False):
        bd   = self._std_border()
        afil = PatternFill("solid", start_color="F8FAFC") if alt else None
        for ci, val in enumerate(values, 1):
            c = ws.cell(row=row, column=ci, value=val)
            c.font = Font(name="Arial", size=9)
            c.alignment = Alignment(horizontal="left" if ci <= 2 else "center", vertical="center")
            c.border = bd
            if afil: c.fill = afil

    def _save_path(self, prefix):
        return filedialog.asksaveasfilename(                            # вийти з методу
            defaultextension=".xlsx", filetypes=[("Excel","*.xlsx")],
            initialfile=f"{prefix}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx")

    def _export_movements_excel(self):

        if not OPENPYXL_OK:
            messagebox.showerror("Помилка",                             # показати помилку
                "Бібліотека openpyxl не встановлена.\n\n"
                "Встановіть її командою:\n"
                ".venv\\Scripts\\python.exe -m pip install openpyxl\n\n"
                "або скористайтесь експортом у форматі CSV.")
            return                                                      # вийти з методу
        path = self._save_path("рухи_товарів")
        if not path: return                                             # вийти з методу
        try:
            wb = Workbook(); ws = wb.active; ws.title = "Рухи"
            movs = self.model.data.get("movements", [])
            ws.merge_cells("A1:H1")
            ws["A1"] = f"Журнал операцій - {datetime.now():%d.%m.%Y %H:%M}"
            ws["A1"].font = Font(name="Arial", bold=True, size=13, color="1E293B")
            ws["A1"].alignment = Alignment(horizontal="center")
            ws.row_dimensions[1].height = 26
            hdrs = [self.T_("col_id"),self.T_("col_date"),self.T_("col_time"),
                    self.T_("col_product"),self.T_("col_type"),self.T_("col_qty"),
                    self.T_("col_balance"),self.T_("col_comment")]
            self._excel_header(ws, 3, hdrs, [8,12,10,34,14,12,12,40])
            running = {}                                                # поточний залишок по кожному товару
            stc = {
                DataModel.TYPE_INCOME:   "16A34A",
                DataModel.TYPE_EXPENSE:  "DC2626",
                DataModel.TYPE_WRITEOFF: "D97706"
            }
            for i, m in enumerate(sorted(movs, key=lambda x: (x["date"],x["time"])), 1):
                n = m["product"]; running.setdefault(n, 0.0)            # назва товару
                if m["type"] == DataModel.TYPE_INCOME: running[n] += m["qty"] # прихід
                else: running[n] -= m["qty"]                            # зменшити поточний залишок
                self._excel_row(ws, i+3, [
                    m["id"],m["date"],m["time"],m["product"],
                    self._type_label(m["type"]),m["qty"],
                    round(running[n],2),m.get("comment","")
                ], alt=(i%2==0))
                ws.cell(row=i+3,column=5).font = Font(name="Arial",size=9,bold=True,
                                                       color=stc.get(m["type"],"000000"))
            ws.freeze_panes = "A4"
            ws.auto_filter.ref = f"A3:H{len(movs)+3}"
            wb.save(path)
            messagebox.showinfo(self.T_("done_title"), self.T_("export_done", path))
        except Exception as e:
            messagebox.showerror(self.T_("error_title"), str(e))        # показати помилку

    def _export_movements_csv(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".csv", filetypes=[("CSV","*.csv")],
            initialfile=f"рухи_{datetime.now():%Y%m%d_%H%M%S}.csv")
        if not path: return                                             # вийти з методу
        try:
            with open(path, "w", encoding="utf-8-sig", newline="") as f:
                wr = csv.writer(f)
                wr.writerow([self.T_("col_id"),self.T_("col_date"),self.T_("col_time"),
                             self.T_("col_product"),self.T_("col_type"),
                             self.T_("col_qty"),self.T_("col_comment")])
                for m in self.model.data.get("movements", []):          # перебрати всі операції
                    wr.writerow([m["id"],m["date"],m["time"],m["product"],
                                 self._type_label(m["type"]),m["qty"],m.get("comment","")])
            messagebox.showinfo(self.T_("done_title"), self.T_("export_done", path))
        except Exception as e:
            messagebox.showerror(self.T_("error_title"), str(e))        # показати помилку

