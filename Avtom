    def refresh_dashboard(self):
        stats = self.model.get_dashboard_stats()
        for key, card in self._kpi_cards.items():
            card.update_value(str(stats[key]))
        self._draw_chart()
        self._refresh_alerts()

    def _draw_chart(self):
        cv = self._chart_cv
        cv.delete("all")
        w = cv.winfo_width()
        h = cv.winfo_height()
        if w < 50:
            return                                                      # вийти з методу
        stats = self.model.get_dashboard_stats()
        data = stats["chart_data"]
        dates = list(data.keys())
        in_v  = [data[d]["in"]  for d in dates]
        out_v = [data[d]["out"] for d in dates]
        n = len(dates)
        if n == 0:
            return                                                      # вийти з методу
        pl, pr, pt, pb = 60, 20, 25, 42
        cw = w - pl - pr
        ch = h - pt - pb
        max_v = max(max(in_v + [0.1]), max(out_v + [0.1]))

        def tx(i): return pl + i * cw / (n - 1) if n > 1 else pl + cw // 2 # вийти з методу
        def ty(v): return pt + ch - (v / max_v) * ch                    # вийти з методу

        # Сітка
        for g in range(6):
            y = pt + g * ch / 5
            cv.create_line(pl, y, w - pr, y, fill=C["border"], dash=(4, 4), width=1)
            val = max_v * (1 - g / 5)
            cv.create_text(pl - 8, y, text=f"{val:.0f}", anchor="e",
                           fill=C["text3"], font=("Segoe UI", 8))

        # Заповнення під лінією доходів
        if len(in_v) >= 2:
            pts = [(tx(i), ty(v)) for i, v in enumerate(in_v)]
            poly_pts = [(pl, pt + ch)] + pts + [(w - pr, pt + ch)]
            cv.create_polygon([c for p in poly_pts for c in p],
                               fill=C["success"], stipple="gray25", outline="")

        # Лінії
        pts_in  = [(tx(i), ty(v)) for i, v in enumerate(in_v)]
        pts_out = [(tx(i), ty(v)) for i, v in enumerate(out_v)]
        if len(pts_in) >= 2:
            cv.create_line(*[c for p in pts_in  for c in p], fill=C["success"], width=2.5, smooth=True)
            cv.create_line(*[c for p in pts_out for c in p], fill=C["danger"],  width=2.5, smooth=True)

        # Точки на лінії доходів
        for i, (xi, yi) in enumerate(pts_in):
            if in_v[i] > 0:
                cv.create_oval(xi - 4, yi - 4, xi + 4, yi + 4,
                                fill=C["success"], outline=C["bg"], width=2)

        # Мітки по осі X
        step = max(1, n // 8)
        for i in range(0, n, step):
            x = tx(i)
            cv.create_text(x, h - 6, text=dates[i][5:], fill=C["text3"], font=("Segoe UI", 8))
            cv.create_line(x, pt, x, pt + ch, fill=C["border"], dash=(2, 6), width=1)

        # Легенда
        lx = w - 160
        cv.create_rectangle(lx, 8, lx + 16, 18, fill=C["success"], outline="")
        cv.create_text(lx + 20, 13, text=self.T_("lbl_income"), anchor="w",
                       fill=C["text3"], font=("Segoe UI", 9))
        cv.create_rectangle(lx, 24, lx + 16, 34, fill=C["danger"], outline="")
        cv.create_text(lx + 20, 29, text=self.T_("lbl_expense"), anchor="w",
                       fill=C["text3"], font=("Segoe UI", 9))

    def _refresh_alerts(self):
        for w in self._alert_frame.winfo_children():
            w.destroy()
        stocks = self.model.get_stocks()                                # отримати залишки
        STATUS_CFG = self._get_status_cfg()                             # конфіги статусів
        alerts = [
            (p, stocks.get(p["name"], 0), self.model.get_status(p, stocks.get(p["name"], 0)))
            for p in self.model.data["products"]
            if self.model.get_status(p, stocks.get(p["name"], 0)) in ("critical", "empty", "order")
        ]
        if not alerts:
            row = tk.Frame(self._alert_frame, bg=C["success_lt"], padx=16, pady=10,
                           highlightthickness=1, highlightbackground=C["success"])
            row.pack(fill="x")
            tk.Label(row, text=self.T_("all_ok"), bg=C["success_lt"],
                     fg=C["success"], font=FNTB).pack(anchor="w")
            return                                                      # вийти з методу
        for p, cur, status in sorted(alerts, key=lambda x: {"empty": 0, "critical": 1, "order": 2}[x[2]]): # конфіг статусу: замовлення
            cfg = STATUS_CFG[status]                                    # конфіг поточного статусу
            row = tk.Frame(self._alert_frame, bg=cfg["bg"], padx=14, pady=8,
                           highlightthickness=1, highlightbackground=cfg["color"])
            row.pack(fill="x", pady=2)
            tk.Label(row, text=cfg["icon"], bg=cfg["bg"], fg=cfg["color"],
                     font=("Segoe UI", 16)).pack(side="left")
            inf = tk.Frame(row, bg=cfg["bg"])
            inf.pack(side="left", padx=10)
            tk.Label(inf, text=p["name"], bg=cfg["bg"], fg=C["text"], font=FNTB).pack(anchor="w")
            days = self.model.get_days_left(p, cur)
            detail = (f"{cfg['label']}  -  {self.T_('col_current')}: {cur} {p.get('unit', self.T_('pcs'))}"
                      f"  -  {self.T_('days_left_txt')} {days} {self.T_('days')}")
            tk.Label(inf, text=detail, bg=cfg["bg"], fg=C["text2"], font=FNTS).pack(anchor="w")
            need = self.model.get_order_qty(p, cur)
            if need > 0:
                badge = tk.Label(row, text=f"  {self.T_('order_qty')} {need:.1f} {p.get('unit', self.T_('pcs'))}  ",
                                  bg=cfg["color"], fg="#FFFFFF", font=FNTB)
                badge.pack(side="right", padx=6, pady=2)

