                it["name"], it["unit"], it["end_stock"]
            ), tags=("new" if is_new else "existing",))

        def do_import():
            added = 0; stock_added = 0; updated = 0
            today = datetime.now().strftime("%Y-%m-%d")                 # сьогоднішня дата
            for it in items:
                name  = it["name"]
                is_new = name not in existing_names
                if is_new and var_add.get():
                    new_id = max((p["id"] for p in self.model.data["products"]), default=0) + 1 # наступний ID товару
                    daily  = round(it["expense"] / 30, 2) if it["expense"] > 0 else 1.0
                    monthly = round(it["expense"], 1) if it["expense"] > 0 else 30.0
                    safety = self.model.calc_safety_stock(daily, 7)
                    self.model.data["products"].append({
                        "id": new_id, "name": name,                     # унікальний номер запису
                        "unit":     it["unit"] or "шт",
                        "category": "Імпорт 1С",
                        "min_stock": max(1, int(daily * 3)),
                        "daily_consumption":   daily,
                        "monthly_consumption": monthly,
                        "delivery_days": 7,                             # термін доставки 7 днів
                        "safety_stock":  safety,
                    })
                    existing_names.add(name)
                    added += 1
                elif not is_new and var_upd.get():
                    p = next((x for x in self.model.data["products"] if x["name"] == name), None)
                    if p and it["unit"]:
                        p["unit"] = it["unit"]
                        updated += 1
                if var_stock.get() and it["end_stock"] > 0:
                    cur  = self.model.get_stocks(name)
                    diff = it["end_stock"] - cur
                    if abs(diff) > 0.001:
                        mov_type = DataModel.TYPE_INCOME if diff > 0 else DataModel.TYPE_EXPENSE
                        new_mid  = max((m["id"] for m in self.model.data["movements"]), default=0) + 1
                        self.model.data["movements"].append({
                            "id": new_mid, "date": today,
                            "time": datetime.now().strftime("%H:%M:%S"),
                            "product": name, "type": mov_type,          # тип операції
                            "qty": round(abs(diff), 3),
                            "comment": f"Імпорт 1С: залишок {it['end_stock']}"
                        })
                        stock_added += 1
            self.model._audit("IMPORT_1C", f"{filepath}: +{added} поз., залишки: {stock_added}")
            self.model.save()                                           # зберегти дані перед виходом
            self._last_mov_count = len(self.model.data["movements"])    # оновити лічильник
            self._load_products(); self._update_product_combos()        # оновити списки вибору товарів
            self._refresh_stock_tab(); self._load_movements(); self.refresh_dashboard() # оновити дашборд
            dlg.destroy()                                               # закрити діалог
            msg = f"✅ Імпорт завершено!\n\nДодано нових позицій: {added}\nЗалишки оновлено: {stock_added}"
            if updated:
                msg += f"\nОновлено існуючих: {updated}"
            messagebox.showinfo("Імпорт завершено", msg)
            self._imp_status.config(
                text=f"✅ Імпортовано {len(items)} позицій з {os.path.basename(filepath)}",
                fg=C["success"])
            self._status(f"Імпорт 1С: +{added} нових, {stock_added} залишків", C["success"])

        br2 = tk.Frame(dlg, bg=C["bg"])
        br2.pack(pady=10)
        ttk.Button(br2, text="✅ Імпортувати", style="Accent.TButton",
                    command=do_import).pack(side="left", padx=6)
        ttk.Button(br2, text="✖ Скасувати", command=dlg.destroy).pack(side="left", padx=6)

    def _get_period_data(self):
        try:
            df_str = self._exp_df.get().strip()
            dt_str = self._exp_dt.get().strip()
            date_from = date_to = ""                                    # початкові порожні дати
            for fmt in ("%d.%m.%Y", "%Y-%m-%d"):                        # пробуємо обидва формати
                try: date_from = datetime.strptime(df_str, fmt).strftime("%Y-%m-%d"); break # парсити дату від
                except ValueError: pass
            for fmt in ("%d.%m.%Y", "%Y-%m-%d"):                        # пробуємо обидва формати
                try: date_to = datetime.strptime(dt_str, fmt).strftime("%Y-%m-%d"); break # парсити дату до
                except ValueError: pass
            if not date_from:                                           # якщо дата не розпарсилась
                date_from = (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d") # 30 днів тому
            if not date_to:
                date_to = datetime.now().strftime("%Y-%m-%d")           # сьогодні
        except Exception:
            date_from = (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d") # 30 днів тому
            date_to   = datetime.now().strftime("%Y-%m-%d")
        result = {}
        for p in self.model.data["products"]:                           # перебрати всі товари
            name = p["name"]; start = 0.0; income = 0.0; expense = 0.0  # ініціалізація для товару
            for m in sorted(self.model.data["movements"], key=lambda x: (x["date"], x["time"])): # операції за хронологією
                if m["product"] != name: continue                       # перейти до наступного
                if m["type"] == DataModel.TYPE_INCOME:                  # прихід
                    qty = m["qty"]
                else:
                    qty = -m["qty"]
                if m["date"] < date_from:                               # якщо до початку періоду
                    start += qty                                        # йде у відкриваючий залишок
                elif m["date"] <= date_to:                              # якщо в межах періоду
                    if m["type"] == DataModel.TYPE_INCOME: income += m["qty"] # прихід
                    else: expense += m["qty"]                           # додати до витрати
            end = start + income - expense                              # закриваючий залишок
            result[name] = {
                "start":   round(start,   3),
                "income":  round(income,  3),
                "expense": round(expense, 3),
                "end":     round(end,     3),
                "unit":    p.get("unit", self.T_("pcs"))
            }
        return result, date_from, date_to                               # вийти з методу

