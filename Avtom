            (self.T_("col_name"),      230, "w"),
            (self.T_("col_unit"),       60, "center"),
            (self.T_("col_category"),  110, "w"),
            (self.T_("col_current"),   120, "center"),
            (self.T_("col_min"),        90, "center"),
            (self.T_("col_safety"),     95, "center"),
            (self.T_("col_reorder"),    95, "center"),
            (self.T_("col_days"),       90, "center"),
            (self.T_("col_order_qty"), 110, "center"),
            (self.T_("col_status"),    150, "center"),
        ]
        for (text, w, anchor), col in zip(hdrs, cols):
            self._st_tree.heading(col, text=text)
            self._st_tree.column(col, width=w, anchor=anchor,
                                  stretch=(col in ("name", "category")))
        self._st_tree.enable_sorting()
        self._st_tree.bind_mousewheel()
        vsb = ttk.Scrollbar(tf, orient="vertical", command=self._st_tree.yview)
